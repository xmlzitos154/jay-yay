#!/usr/bin/env bash

list_aur() {
    step "Filtrando pacotes instalados via AUR..."
    pacman -Qm | column -t
    TAG="LOCAL_QUERY (AUR)"
    local count=$(yay -Qm | wc -l)
    echo -e "\n${GREEN}$COMPLETE${NC} Total de $count pacotes AUR encontrados."
}

refresh_mirrors() {
    step "Iniciando otimização de mirrors (Reflector)..."
    if ! command -v reflector &>/dev/null; then
        echo -e "${YELLOW}$NOTE Reflector não encontrado.${NC}"
        read -p "Deseja instalar o reflector para otimizar mirrors? [S/n] " -n 1 -r
        echo
        if [[ $REPLY =~ ^[Ss]$ ]]; then
            sudo pacman -S reflector --noconfirm
        else
            error "Reflector é necessário para esta função."
        fi
    fi

    step "Criando backup em /etc/pacman.d/mirrorlist.bak"
    sudo cp /etc/pacman.d/mirrorlist /etc/pacman.d/mirrorlist.bak
    step "Buscando os 10 mirrors mais rápidos no Brasil... (Aguarde)"
    if sudo reflector --country Brazil --latest 10 --sort rate --save /etc/pacman.d/mirrorlist; then
        success "Mirrors atualizados e salvos com sucesso."
        TAG="UPDATE MIRRORS"
    else
        error "Falha ao atualizar mirrors. Verifique sua conexão."
    fi
}

fix_keys() {
    step "Iniciando recuperação de chaves GPG..."
    yay -Sy archlinux-keyring --noconfirm
    if [[ -f "$TMP_OUT" ]]; then
        local keys=$(grep -oP '(?<=key\s)([A-F0-9]{16,})|(?<=ID\s)([A-F0-9]{16,})' "$TMP_OUT" | sort -u)
        
        if [[ -n "$keys" ]]; then
            for key in $keys; do
                step "Importando chave: $key"
                gpg --recv-keys "$key" || gpg --keyserver hkp://keyserver.ubuntu.com:80 --recv-keys "$key"
            done
        fi
    fi
    step "Limpando caches de chaves corrompidas..."
    sudo find /etc/pacman.d/gnupg -type f -name "*.lck" -delete
    sudo pacman-key --init
    sudo pacman-key --populate archlinux
    
    success "Procedimento de chaves finalizado."
    TAG="SKIP"
}