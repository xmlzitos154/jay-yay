#!/usr/bin/env bash

list_aur() {
    step "Filtrando pacotes instalados via AUR..."
    pacman -Qm | column -t
    TAG="[LOCAL_QUERY (AUR)]"
    local count=$(yay -Qm | wc -l)
    echo -e "\n${GREEN}$OK${NC} Total de $count pacotes AUR encontrados."
}

refresh_mirrors() {
    tester
    echo "$WARNING Procurando mirrors..."
    sudo cp /etc/pacman.d/mirrorlist /etc/pacman.d/mirrorlist.bak
    sudo reflector --country Brazil --latest 10 --sort rate --save /etc/pacman.d/mirrorlist
    echo "$OK Mirrors atualizados"
    TAG="[UPDATED MIRRORS]"
}

fix_keys() {
    step "Iniciando recuperação de chaves GPG..."
    yay -Sy archlinux-keyring --noconfirm
    if [[ -f "$TMP_OUT" ]]; then
        local keys=$(grep -oP '(?<=key\s)([A-F0-9]{16,})|(?<=ID\s)([A-F0-9]{16,})' "$TMP_OUT" | sort -u)
        
        if [[ -n "$keys" ]]; then
            for key in $keys; do
                step "Importando chave: $key"
                gpg --recv-keys "$key" || gpg --keyserver hkp://keyserver.ubuntu.com:80 --recv-keys "$key"
            done
        fi
    fi
    step "Limpando caches de chaves corrompidas..."
    sudo find /etc/pacman.d/gnupg -type f -name "*.lck" -delete
    sudo pacman-key --init
    sudo pacman-key --populate archlinux
    
    success "Procedimento de chaves finalizado."
    TAG="SKIP"
}