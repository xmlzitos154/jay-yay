#!/usr/bin/env bash

clr_cache() {
    CMD="-Sc"
    TAG="[CLEANED CACHE]"
}

remove_orphans() {
    step "Buscando pacotes órfãos..."
    ORPHANS=$(yay -Qdtq)
    if [[ -n "$ORPHANS" ]]; then
        step "Removendo: $ORPHANS"
        yay -Rsn $ORPHANS
        EXIT_CODE=$?
        if [[ $EXIT_CODE -eq 0 ]]; then
            success "Órfãos removidos com sucesso."
            logger "[ORPHAN REMOVED]" "ALL_ORPHANS"
        else
            error "Falha ao remover órfãos."
        fi
    else
        success "Nenhum pacote órfão encontrado."
    fi
    exit 0
}