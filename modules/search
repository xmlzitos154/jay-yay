#!/usr/bin/env bash

searcher() {
    tester
    CMD="-Ss"
    TAG="SEARCHED"
    FLAT_CMD="search"
}

query() {
    CMD="-Qs"
    TAG="LOCAL QUERY"
}

check_updates() {
    tester
    step "Procurando pacotes desatualizados..."
    UPDS="$(checkupdates 2>/dev/null | wc -l)"
    if [[ "$UPDS" == "0" ]]; then
        success "Nenhuma atualização encontrada."
        exit 0
    fi
    echo -e "${YELLOW} $NOTE $UPDS Atualizações encontradas: ${NC}"
    echo " $(checkupdates)"
    exit 0
}
