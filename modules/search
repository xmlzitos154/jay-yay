#!/usr/bin/env bash

searcher() {
    tester
    CMD="-Ss"
    TAG="SEARCHED"
    FLAT_CMD="search"
}

query() {
    CMD="-Qs"
    TAG="LOCAL QUERY"
}

check_updates() {
    tester
    step "Procurando pacotes desatualizados..."
    UPDS="$(checkupdates)"
    UPDS_N="$(checkupdates 2>/dev/null | wc -l)"
    if [[ "$UPDS_N" == "0" ]]; then
        success "Nenhuma atualização encontrada."
    fi
    echo -e "${YELLOW} $NOTE $UPDS Atualizações encontradas: ${NC}"
    echo "$UPDS"
    logger "FOUND UPDATES" "$UPDS"
}
