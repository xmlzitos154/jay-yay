#!/usr/bin/env bash

VER="2.2 (Yogourt)"

REAL_HOME=$(getent passwd "$SUDO_USER" | cut -d: -f6)
REAL_HOME=${REAL_HOME:-$HOME}

MODULES_DIR="$REAL_HOME/.config/jay/modules"
LOG_FILE="$REAL_HOME/.cache/jaylog.txt"
CONFIG_DIR="$REAL_HOME/.config/jay"

CYAN='\033[0;36m'
GREEN='\033[0;32m'
YELLOW='\033[1;33m'
RED='\033[0;31m'
NC='\033[0m'

ALERT="[!]"
ERROR="[x]"
OK="[✓]"
WARNING="[*]"
CONTINUE="[>>]"

msg01() {
    echo -e -n "${CYAN} $ERROR ${NC}" && echo "argumento invalido '$VAR'" | tr -d "-"
    exit 1
}

msg02() {
    echo -e -n "${CYAN} $ERROR ${NC}" && echo "argumento invalido '-'"
    exit 1
}

msg03() {
    echo -e "\n ${CYAN}-> JAY (Just Another Yogourt) - Version $VER ${NC}\n"
}

msg04() {
    echo -e "${RED}$ERROR Módulo $MISSING_MODULE não encontrado${NC}\n -> saindo com status 1"
    exit 1
}

[[ -f "$LOG_FILE" ]] || touch "$LOG_FILE"

if [[ ! -f "$MODULES_DIR/base" ]]; then
    MISSING_MODULE="base"
    msg04
fi
if [[ ! -f "$MODULES_DIR/log" ]]; then
    MISSING_MODULE="log"
    msg04
fi

source "$MODULES_DIR/base"
source "$MODULES_DIR/log"

[[ -f "$MODULES_DIR/cache" ]] && source "$MODULES_DIR/cache" || MOD_1="0"
[[ -f "$MODULES_DIR/search" ]] && source "$MODULES_DIR/search" || MOD_2="0"
[[ -f "$MODULES_DIR/extra" ]] && source "$MODULES_DIR/extra" || MOD_3="0"

step() { echo -e "${CYAN} $CONTINUE ${NC}${1}"; }
success() { echo -e "${GREEN} $OK ${NC}${1}"; }
error() { echo -e "${RED} $ERROR ${NC}${1}"; exit 1; }

logger() {
    local tag="$1"
    local info="$2"
    local date_str=$(date "+%H:%M - %d/%m/%Y")
    echo "($date_str) | $tag | $info" >> "$LOG_FILE"
}

help_message() {
    msg03
    echo -e "Uso: jay [comando] [opções] [pacotes]"
    echo -e "Uso: jay [ -i | -rm | -s | -u ] [ -f | --flatpak ] [ --noconfirm ]"
    echo -e "Uso: jay [ -q | query ] [ --list-aur ]"
    echo -e "Options: \n"
    echo -e "-h,  --help         Mostra essa mensagem"
    echo -e "-i,  install        Sincronizar pacotes"
    echo -e "-rm, remove         Remover pacotes (Use '-A' para modo Agressivo)"
    echo -e "-u,  update         Atualizar o sistema"
    if [[ "$MOD_2" != "0" ]]; then
        echo -e "-s,  search         Pesquisa pacotes no AUR"
        echo -e "-q,  query          Pesquisa pacotes locais"
    fi
    if [[ "$MOD_1" != "0" ]]; then
        echo -e "-o,  orphan         Remove dependências inúteis"
        echo -e "-c,  cache          Limpa todo o cache do pacman"
    fi
    if [[ "$MOD_3" != "0" ]]; then
        echo -e "-m, mirrors         Procura repositorios velozes"
    fi
    exit 0
}

usage() {
    echo -e "${RED} $ERROR Uso: jay <comando> <pacotes>${NC}"
    exit 1
}

[[ -z "$1" ]] && usage
RAW_CMD="$*"
ACTION="$1"
shift

USE_FLATPAK=false
AGRESSIVE_MODE=false
FINAL_ARGS=()
YAY_FLAGS=()

for arg in "$@"; do
    if [[ "$arg" == "--list-aur" ]]; then
        if [[ "$ACTION" =~ ^(query|-q)$ ]]; then
            if [[ "$MOD_3" != "0" ]]; then
                list_aur
                exit 0
            else
                echo -e "$WARNING Modulo 'extra' necessario."
                exit 1
            fi
        fi
    elif [[ "$arg" == "-f" || "$arg" == "--flatpak" ]]; then
        USE_FLATPAK=true
    elif [[ "$arg" == "-A" ]]; then
        if [[ "$ACTION" =~ ^(remove|-rm)$ ]]; then
            AGRESSIVE_MODE=true
            CMD="-Rsn"
            TAG="[REMOVED-AGRESSIVE]"
        fi
    elif [[ "$arg" == "--kill-dblck" ]]; then
        if [[ -f /var/lib/pacman/db.lck ]]; then
            step "Removendo trava do banco de dados..."
            sudo rm /var/lib/pacman/db.lck && success "Trava removida."
        else
            echo "$WARNING Nenhuma trava de banco de dados encontrada."
        fi
    elif [[ "$arg" == -* ]]; then
        YAY_FLAGS+=("$arg")
    else
        FINAL_ARGS+=("$arg")
    fi
done

case "$ACTION" in
    "-") msg02 ;;
    install|-i|-S) ins ;;
    remove|-rm) rmv ;;
    refresh|-r) rfs ;;
    update|-u) upd ;;
    slog|-sl) show_logs ;;
    clog|-cl) clear_logs ;;
    search|-s)
        [[ "$MOD_2" == "0" ]] && { echo "$WARNING Módulo search não carregado."; exit 1; } || searcher
    ;;
    query|-q)
        [[ "$MOD_2" == "0" ]] && { echo "$WARNING Módulo search não carregado."; exit 1; } || query
    ;;
    cache|-c)
        [[ "$MOD_1" == "0" ]] && { echo "$WARNING Módulo cache não carregado."; exit 1; } || clr_cache
    ;;
    orphan|-o)
        [[ "$MOD_3" == "0" ]] && { echo "$WARNING Módulo extra não carregado."; exit 1; } || remove_orphans
    ;;
    -m|mirrors)
        [[ "$MOD_3" == "0" ]] && { echo "$WARNING Módulo extra não carregado."; exit 1; } || refresh_mirrors
    ;;
    -v|--version) msg03; exit 0 ;;
    -h|--help) help_message ;;
    *)
        VAR="$ACTION"
        msg01
    ;;
esac

if [[ "$ACTION" =~ ^(install|remove|-i|-rm)$ && ${#FINAL_ARGS[@]} -eq 0 ]]; then
    error "Informe ao menos um pacote."
fi

command -v yay &>/dev/null || error "yay não encontrado."

[[ "$USE_FLATPAK" == "true" ]] && FLAT_FLAGS="-y" || FLAT_FLAGS=""
TMP_OUT=$(mktemp)

if [[ "$ACTION" != "orphan" && "$ACTION" != "-o" ]]; then
    [[ "$AGRESSIVE_MODE" == "true" ]] && echo -e "${RED} $ALERT Modo agressivo ativado!${NC}"
    step "Iniciando processo via AUR..."
    yay "$CMD" "${FINAL_ARGS[@]}" "${YAY_FLAGS[@]}" 2>&1 | tee "$TMP_OUT"
    EXIT_CODE=${PIPESTATUS[0]}
fi

if [[ "$USE_FLATPAK" == "true" ]]; then
    if [[ "$ACTION" =~ ^(update|-u)$ ]]; then
        step "Atualizando Flatpaks..."
        command -v flatpak &>/dev/null && flatpak update $FLAT_FLAGS
        elif [[ "$ACTION" =~ ^(search|-s)$ ]]; then
        step "Buscando no Flatpak..."
        command -v flatpak &>/dev/null && flatpak search "${FINAL_ARGS[@]}"
        elif [[ $EXIT_CODE -ne 0 ]] || grep -qiE "Nenhum pacote AUR localizado|não há nada a ser feito|target not found" "$TMP_OUT"; then
        echo -e "\n${YELLOW} $ALERT AUR não encontrou nada. Pulando para Flatpak...${NC}\n"
        if command -v flatpak &>/dev/null; then
            flatpak $FLAT_CMD $FLAT_FLAGS "${FINAL_ARGS[@]}"
            EXIT_CODE=$?
            [[ $EXIT_CODE -eq 0 ]] && { [[ "$FLAT_CMD" == "uninstall" ]] && TAG="[RM FLATPAK]" || TAG="[FLATPAK]"; }
        fi
    fi
fi

if [[ "$TAG" != "SKIP" ]]; then
    if [[ $EXIT_CODE -ne 0 ]]; then
        TAG="[!] Command failed"
        PKGS_TO_LOG="$RAW_CMD"
        elif [[ "$ACTION" =~ ^(update|-u)$ ]]; then
        PKGS_TO_LOG=$(sed 's/\x1b\[[0-9;]*[mGJK]//g' "$TMP_OUT" | grep -E "upgraded|atualizado" | awk '{print $3}' | tr '\n' ',' | sed 's/,$//')
    else
        PKGS_TO_LOG=$(IFS=','; echo "${FINAL_ARGS[*]}")
    fi
    
    FINAL_TEXT="${PKGS_TO_LOG:-SYSTEM}"
    logger "$TAG" "$FINAL_TEXT"
fi

success "Operação finalizada."