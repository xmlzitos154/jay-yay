#!/usr/bin/env bash

VER="1.2.0"

if ! command -v yay &>/dev/null; then
    echo "Erro: yay não está instalado."
    exit 1
fi

LOG_FILE="$HOME/.cache/jaylog.txt"
LOG_DATE="$(date "+%H:%M - %d/%m/%Y")"

[[ -f "$LOG_FILE" ]] || touch "$LOG_FILE"

help_usage() {
    echo "jay usage: [Command] [Packages]"
    exit 1
}

help_msg() {
    echo "JAY - a simple yay wrapper. version: $VER"
    echo -e "Commands:\n"
    echo "  install    (Sync apps)       |  remove     (Remove apps)"
    echo "  refresh    (Refresh repos)   |  update     (Update system)"
    echo "  search     (Search AUR/Repo) |  query      (Local search)"
    echo "  cache      (Clear cache - may remove old packages)"
    echo -e "\nLogger:\n"
    echo "  slog       (Show logs)       |  clog       (Clear logs)"
    echo "  help       (Show this list)"
    exit 0
}

ARG="$1"
CMD=""
LOGGER=""

ARGS=()
NOCONFIRM=""

for arg in "${@:2}"; do
    if [[ "$arg" == "--noconfirm" || "$arg" == "-y" ]]; then
        NOCONFIRM="--noconfirm"
    else
        ARGS+=("$arg")
    fi
done

PKGS="${ARGS[*]}"

[[ -z "$ARG" ]] && help_usage

case "$ARG" in
    "install") CMD="-S"   ; LOGGER="[INSTALLED]" ;;
    "remove")  CMD="-Rsn" ; LOGGER="[REMOVED]"   ;;
    "refresh") CMD="-Syy" ; LOGGER="[REFRESHED]" ;;
    "update")  CMD="-Syu" ; LOGGER="[UPDATED]"   ;;
    "search")  CMD="-Ss"  ; LOGGER="[SEARCHED]"  ;;
    "query")   CMD="-Qs"  ; LOGGER="[QUERIED]"   ;;
    "cache")
        read -rp "Limpar cache? [y/N]: " confirm
        [[ $confirm =~ ^[Yy]$ ]] || exit 0
        CMD="-Sc"
        LOGGER="[CACHE CLEAN]"
    ;;
    "slog")
    [[ ! -s "$LOG_FILE" ]] && { echo "Nenhum log encontrado."; exit 0; }
        sed -e 's/\[INSTALLED\]/\x1b[32m&\x1b[0m/' \
        -e 's/\[REMOVED\]/\x1b[31m&\x1b[0m/' \
        -e 's/\[ERROR\]/\x1b[41;37m&\x1b[0m/' "$LOG_FILE" | column -t -s '|'
    exit 0 ;;
    "clog")
    > "$LOG_FILE" ; echo "Logs limpos." ; exit 0 ;;
    --help|-h|help) help_msg ;;
    ver|--version|-v) echo -e "\n JAY version: $VER \n" ; exit 0 ;;
    *) help_usage ;;
esac

if [[ "$ARG" =~ ^(install|remove)$ ]] && [[ ${#ARGS[@]} -eq 0 ]]; then
    echo "Nenhum programa especificado."
    exit 0
fi

if yay "$CMD" "${ARGS[@]}" ${NOCONFIRM:+$NOCONFIRM}; then
    FINAL_LOG="($LOG_DATE)|$LOGGER|${PKGS:-SYSTEM}"
    echo "$FINAL_LOG" >> "$LOG_FILE"
else
    ERROR_MSG="($LOG_DATE)|[ERROR]|$ARG $PKGS"
    echo "$ERROR_MSG" >> "$LOG_FILE"
    echo "ERRO ao executar comando: jay $ARG $PKGS"
    echo "Verifique os logs em $LOG_FILE."
    exit 1
fi