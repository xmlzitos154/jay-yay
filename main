#!/usr/bin/env bash

VER="1.2.1"

if ! command -v yay &>/dev/null; then
    echo "erro: yay não está instalado."
    exit 1
fi

LOG_FILE="$HOME/.cache/jaylog.txt"
[[ -f "$LOG_FILE" ]] || touch "$LOG_FILE"

help_usage() {
    echo "jay usage: [Command] [Packages]"
    exit 1
}

help_msg() {
    printf "JAY - a simple yay wrapper. version: %s\n" "$VER"
    printf "Commands:\n\n"
    printf "  install    (Sync apps)       |  remove     (Remove apps)\n"
    printf "  refresh    (Refresh repos)   |  update     (Update system)\n"
    printf "  search     (Search AUR/Repo) |  query      (Local search)\n"
    printf "  cache      (Clear cache - may remove old packages)\n"
    printf "\nLogger:\n\n"
    printf "  slog       (Show logs)       |  clog       (Clear logs)\n"
    printf "  help       (Show this list)\n"
    exit 0
}

ARG="$1"
CMD=""
LOGGER=""
ARGS=()
NOCONFIRM=()

for arg in "${@:2}"; do
    if [[ "$arg" == "--noconfirm" || "$arg" == "-y" ]]; then
        NOCONFIRM=("--noconfirm")
    else
        ARGS+=("$arg")
    fi
done

[[ -z "$ARG" ]] && help_usage

case "$ARG" in
    "install")
        CMD="-S"
        LOGGER="[INSTALLED]"
        ;;
    "remove")
        CMD="-Rsn"
        LOGGER="[REMOVED]"
        ;;
    "refresh")
        [[ ${#ARGS[@]} -gt 0 ]] && echo "Aviso: argumentos ignorados para 'refresh'."
        ARGS=()
        CMD="-Syy"
        LOGGER="[REFRESHED]"
        ;;
    "update")
        [[ ${#ARGS[@]} -gt 0 ]] && echo "Aviso: argumentos ignorados para 'update'."
        ARGS=()
        CMD="-Syu"
        LOGGER="[UPDATED]"
        ;;
    "search")
        CMD="-Ss"
        LOGGER="[SEARCHED]"
        ;;
    "query")
        CMD="-Qs"
        LOGGER="[QUERIED]"
        ;;
    "cache")
        [[ ${#ARGS[@]} -gt 0 ]] && echo "Aviso: argumentos ignorados para 'cache'."
        ARGS=()
        read -rp "Limpar cache? [y/N]: " confirm
        [[ $confirm =~ ^[Yy]$ ]] || exit 0
        CMD="-Sc"
        LOGGER="[CACHE CLEAN]"
        ;;
    "slog")
        [[ ! -s "$LOG_FILE" ]] && { echo "Nenhum log encontrado."; exit 0; }
        sed -e 's/\[INSTALLED\]/\x1b[32m&\x1b[0m/' \
            -e 's/\[REMOVED\]/\x1b[31m&\x1b[0m/' \
            -e 's/\[ERROR\]/\x1b[41;37m&\x1b[0m/' "$LOG_FILE" | column -t -s '|'
        exit 0
        ;;
    "clog")
        > "$LOG_FILE"
        echo "Logs limpos."
        exit 0
        ;;
    --help|-h|help)
        help_msg
        ;;
    ver|--version|-v)
        printf "\n JAY version: %s \n\n" "$VER"
        exit 0
        ;;
    *)
        help_usage
        ;;
esac

if [[ "$ARG" =~ ^(install|remove)$ ]] && [[ ${#ARGS[@]} -eq 0 ]]; then
    echo "Nenhum programa especificado."
    exit 1
fi

if [[ "$ARG" =~ ^(search|query)$ ]] && [[ ${#ARGS[@]} -eq 0 ]]; then
    echo "Informe um termo para busca."
    exit 1
fi

PKGS=$(IFS=','; echo "${ARGS[*]}")

OUTPUT=$(yay "$CMD" "${ARGS[@]}" "${NOCONFIRM[@]}" 2>&1)
STATUS=$?

echo "$OUTPUT"

if [[ $STATUS -eq 0 && "$OUTPUT" != *"não há nada a ser feito"* && "$OUTPUT" != *"Nothing to do"* ]]; then
    LOG_DATE="$(date "+%H:%M - %d/%m/%Y")"
    echo "($LOG_DATE)|$LOGGER|${PKGS:-SYSTEM}" >> "$LOG_FILE"
else
    LOG_DATE="$(date "+%H:%M - %d/%m/%Y")"
    echo "($LOG_DATE)|[ERROR]|$ARG ${PKGS:-SYSTEM}" >> "$LOG_FILE"
    echo "ERRO ao executar comando: jay $ARG ${PKGS:-SYSTEM}"
    exit 1
fi