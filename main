#!/usr/bin/env bash

VER="1.4.6"
LOG_FILE="$HOME/.cache/jaylog.txt"
[[ -f "$LOG_FILE" ]] || touch "$LOG_FILE"

ALERT="[!]"
ERROR="[x]"
OK="[✓]"
WARNING="[*]"
CONTINUE="[>>]"

CYAN='\033[0;36m'
GREEN='\033[0;32m'
YELLOW='\033[1;33m'
RED='\033[0;31m'
NC='\033[0m'

step() { echo -e "${CYAN} $CONTINUE ${NC}${1}"; }
success() { echo -e "${GREEN} $OK ${NC}${1}"; }
error() { echo -e "${RED} $ERROR ${NC}${1}"; exit 1; }

logger() {
    local tag="$1"
    local info="$2"
    local date_str=$(date "+%H:%M - %d/%m/%Y")
    echo "($date_str) | $tag | $info" >> "$LOG_FILE"
}

msg01() {
    echo -e -n "${CYAN} $ERROR ${NC}" && echo "argumento invalido '$VAR'" | tr -d "-"
    exit 1
}

msg02() {
    echo -e -n "${CYAN} $ERROR ${NC}" && echo "argumento invalido '-'"
    exit 1
}

msg03() {
    echo -e "\n ${CYAN}-> JAY (Just Another Yogourt) - Version $VER ${NC}\n"
}

help_message() {
    msg03
    echo -e "Uso: jay [comando] [opções] [pacotes]"
    echo -e "Uso: jay [ -i | -rm | -s | -u ] [ -f | --flatpak ] [ --noconfirm ]"
    echo -e "Options: \n"
    echo -e "-h,  --help         Mostra essa mensagem"
    echo -e "-i,  install        Sincronizar pacotes"
    echo -e "-rm, remove         Remover pacotes (Use '-A' para modo Agressivo)"
    echo -e "-s,  search         Pesquisar pacotes"
    echo -e "-u,  update         Atualizar o sistema"
    echo -e "-o,  orphan         Remove dependências inúteis"
    exit 0
}

usage() {
    echo -e "${RED} $ERROR Uso: jay <comando> <pacotes>${NC}"
    exit 1
}

tester() {
    step "Testando rede..."
    if ping 8.8.8.8 -c 1 &>/dev/null; then
        success "Conexão ativa. Continuando..."
    else
        error "Internet desconectada. Saindo com status 1"
    fi
}

remove_orphans() {
    step "Buscando pacotes órfãos..."
    ORPHANS=$(yay -Qdtq)
    if [[ -n "$ORPHANS" ]]; then
        step "Removendo: $ORPHANS"
        yay -Rsn $ORPHANS
        EXIT_CODE=$?
        if [[ $EXIT_CODE -eq 0 ]]; then
            success "Órfãos removidos com sucesso."
            logger "[ORPHAN REMOVED]" "ALL_ORPHANS"
        else
            error "Falha ao remover órfãos."
        fi
    else
        success "Nenhum pacote órfão encontrado."
    fi
    exit 0
}

[[ -z "$1" ]] && usage

RAW_CMD="$*"
USE_FLATPAK=false
AGRESSIVE_MODE=false

if [[ "$1" == "-f" || "$1" == "--flatpak" ]]; then
    USE_FLATPAK=true
    shift
fi

case "$1" in
    "-") msg02 ;;
    install|-i|-S) tester; CMD="-S"; TAG="[INSTALLED]"; FLAT_CMD="install flathub" ;;
    remove|-rm) CMD="-R"; TAG="[REMOVED]"; FLAT_CMD="uninstall" ;;
    refresh|-r) tester; CMD="-Syy"; TAG="[REFRESHED]" ;;
    update|-u) tester; CMD="-Syu"; TAG="[UPDATED]"; FLAT_CMD="update" ;;
    search|-s) tester; CMD="-Ss"; TAG="[SEARCHED]"; FLAT_CMD="search" ;;
    query|-q) CMD="-Qs"; TAG="[LOCAL_QUERY]" ;;
    cache|-c) CMD="-Sc"; TAG="[CACHE CLEAN]" ;;
    slog|-sl) [[ ! -s "$LOG_FILE" ]] && { echo "Log vazio."; exit 0; }; column -t -s '|' "$LOG_FILE"; exit 0 ;;
    clog|-cl) > "$LOG_FILE"; success "Logs limpos."; exit 0 ;;
    orphan|-o) remove_orphans ;;
    -v|--version) msg03; exit 0 ;;
    -h|--help) help_message ;;
    *) VAR="$1"; msg01 ;;
esac

ACTION="$1"
shift

FINAL_ARGS=()
YAY_FLAGS=()

for arg in "$@"; do
    if [[ "$arg" == "-f" || "$arg" == "--flatpak" ]]; then
        USE_FLATPAK=true
    elif [[ "$arg" == "-A" ]]; then
        if [[ "$ACTION" =~ ^(remove|-rm)$ ]]; then
            AGRESSIVE_MODE=true
            CMD="-Rsn"
            TAG="[REMOVED-AGRESSIVE]"
        fi
    elif [[ "$arg" == -* ]]; then
        YAY_FLAGS+=("$arg")
    else
        FINAL_ARGS+=("$arg")
    fi
done

if [[ "$ACTION" =~ ^(install|remove|-i|-rm)$ && ${#FINAL_ARGS[@]} -eq 0 ]]; then
    error "Informe ao menos um pacote."
fi

command -v yay &>/dev/null || error "yay não encontrado."

[[ "$USE_FLATPAK" == "true" ]] && FLAT_FLAGS="-y" || FLAT_FLAGS=""
TMP_OUT=$(mktemp)

if [[ "$ACTION" != "orphan" && "$ACTION" != "-o" ]]; then
    [[ "$AGRESSIVE_MODE" == "true" ]] && echo -e "${RED} $ALERT Modo agressivo ativado!${NC}"
    step "Iniciando processo via AUR..."
    yay "$CMD" "${FINAL_ARGS[@]}" "${YAY_FLAGS[@]}" 2>&1 | tee "$TMP_OUT"
    EXIT_CODE=${PIPESTATUS[0]}
fi

if [[ "$USE_FLATPAK" == "true" ]]; then
    if [[ "$ACTION" =~ ^(update|-u)$ ]]; then
        step "Atualizando Flatpaks..."
        command -v flatpak &>/dev/null && flatpak update $FLAT_FLAGS
    elif [[ "$ACTION" =~ ^(search|-s)$ ]]; then
        step "Buscando no Flatpak..."
        command -v flatpak &>/dev/null && flatpak search "${FINAL_ARGS[@]}"
    elif [[ $EXIT_CODE -ne 0 ]] || grep -qiE "Nenhum pacote AUR localizado|não há nada a ser feito|target not found" "$TMP_OUT"; then
        echo -e "\n${YELLOW} $ALERT AUR não encontrou nada. Pulando para Flatpak...${NC}\n"
        if command -v flatpak &>/dev/null; then
            flatpak $FLAT_CMD $FLAT_FLAGS "${FINAL_ARGS[@]}"
            EXIT_CODE=$?
            [[ $EXIT_CODE -eq 0 ]] && { [[ "$FLAT_CMD" == "uninstall" ]] && TAG="[RM FLATPAK]" || TAG="[FLATPAK]"; }
        fi
    fi
fi

if [[ "$TAG" != "SKIP" ]]; then
    if [[ $EXIT_CODE -ne 0 ]]; then
        TAG="[!] Command failed"
        PKGS_TO_LOG="$RAW_CMD"
    elif [[ "$ACTION" =~ ^(update|-u)$ ]]; then
        PKGS_TO_LOG=$(sed 's/\x1b\[[0-9;]*[mGJK]//g' "$TMP_OUT" | grep -E "upgraded|atualizado" | awk '{print $3}' | tr '\n' ',' | sed 's/,$//')
    else
        PKGS_TO_LOG=$(IFS=','; echo "${FINAL_ARGS[*]}")
    fi
    
    FINAL_TEXT="${PKGS_TO_LOG:-SYSTEM}"
    logger "$TAG" "$FINAL_TEXT"
fi

success "Operação finalizada."