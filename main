#!/usr/bin/env bash

# --- Configurações ---
VER="1.3.5"
LOG_FILE="$HOME/.cache/jaylog.txt"
[[ -f "$LOG_FILE" ]] || touch "$LOG_FILE"

# --- Interface Simples ---

usage() {
    echo "Uso: jay [comando] [pacotes]"
    exit 1
}

# --- Lógica de Comandos ---

[[ -z "$1" ]] && usage

case "$1" in
    install) CMD="-S";   TAG="[INSTALLED]" ;;
    remove)  CMD="-Rsn"; TAG="[REMOVED]"   ;;
    refresh) CMD="-Syy"; TAG="[REFRESHED]" ;;
    update)  CMD="-Syu"; TAG="[UPDATED]"   ;;
    search)  CMD="-Ss";  TAG="SKIP"        ;;
    query)   CMD="-Qs";  TAG="SKIP"        ;;
    cache)   CMD="-Sc";  TAG="[CACHE CLEAN]" ;;
    slog)
        [[ ! -s "$LOG_FILE" ]] && { echo "Log vazio."; exit 0; }
        column -t -s '|' "$LOG_FILE"
        exit 0 ;;
    clog) 
        > "$LOG_FILE"
        echo "Logs limpos."
        exit 0 ;;
    -v|--version) 
        echo "jay v$VER"
        exit 0 ;;
    *) usage ;;
esac

# --- Filtro de Argumentos (Separa pacotes de flags como --noconfirm) ---

ACTION="$1"
shift
FINAL_ARGS=()
YAY_FLAGS=()

for arg in "$@"; do
    if [[ "$arg" == -* ]]; then
        YAY_FLAGS+=("$arg")
    else
        FINAL_ARGS+=("$arg")
    fi
done

# Validação para comandos de modificação
if [[ "$ACTION" =~ ^(install|remove)$ && ${#FINAL_ARGS[@]} -eq 0 ]]; then
    echo "Erro: Informe ao menos um pacote."
    exit 1
fi

if ! command -v yay &>/dev/null; then 
    echo "Erro: yay não encontrado."
    exit 1 
fi

# --- Execução Principal ---

TMP_OUT=$(mktemp)
# Roda o yay normalmente
yay "$CMD" "${FINAL_ARGS[@]}" "${YAY_FLAGS[@]}" 2>&1 | tee "$TMP_OUT"
EXIT_CODE=$?

# --- Registro de Log (Texto Puro) ---

if [[ "$TAG" != "SKIP" ]]; then
    DATE_STR=$(date "+%H:%M - %d/%m/%Y")
    
    # Se for update, tenta extrair os nomes dos pacotes da saída do yay
    if [[ "$ACTION" == "update" && $EXIT_CODE -eq 0 ]]; then
        # Limpa caracteres de controle ANSI que o yay solta e filtra nomes
        PKGS_TO_LOG=$(sed 's/\x1b\[[0-9;]*[mGJK]//g' "$TMP_OUT" | grep -E "upgraded|atualizado" | awk '{print $3}' | tr '\n' ',' | sed 's/,$//')
    else
        # Usa apenas os pacotes da lista de argumentos (sem flags)
        PKGS_TO_LOG=$(IFS=','; echo "${FINAL_ARGS[*]}")
    fi

    FINAL_TEXT="${PKGS_TO_LOG:-SYSTEM}"

    if [[ $EXIT_CODE -eq 0 ]]; then
        echo "($DATE_STR) | $TAG | $FINAL_TEXT" >> "$LOG_FILE"
    else
        echo "($DATE_STR) | [ERROR] | $ACTION: $FINAL_TEXT" >> "$LOG_FILE"
    fi
fi

rm "$TMP_OUT"