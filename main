load_language

## !FUNCTIONS

step() { echo -e "${BOLD}${GREEN}$CC ${1}${NC}"; }
success() { echo -e "${GREEN} $COMPLETE ${NC}${1}"; }
error() { echo -e "${RED} $ERROR ${NC}${1}"; exit 1; }

err01() { echo -e "$ALERT $MSG_ERR01 '$action'"; exit 1; }
err02() { echo -e "${RED}$ERROR $MSG_ERR02"; exit 1; }
err03() { echo -e "${RED}$ERROR $MSG_ERR03"; exit 1; }
err04() { echo -e "${RED}$ERROR $MSG_ERR04"; exit 1; }
err05() { echo -e "${RED}$ERROR $MSG_ERR05"; exit 1; }
err06() { echo -e "${RED}$ERROR $MSG_ERR06"; exit 1; }
usage() { echo -e "$HLP_USAGE: jay [command] [options] [packages]"; exit 1; }

if command -v yay &>/dev/null; then
    echo -e "${GREEN}${BOLD}$CC $MSG_USING_BACKEND yay...${NC}"
    backend="yay"
    elif command -v paru &>/dev/null; then
    echo -e " ${CYAN}${BOLD}$NOTE paru $MSG_DETECTED paru...${NC}"
    backend="paru"
    elif command -v pikaur &>/dev/null; then
    echo -e " ${CYAN}${BOLD}$NOTE pikaur $MSG_DETECTED pikaur...${NC}"
    backend="pikaur"
else
    echo -e "${RED}$MSG_AUR_HELPER_NOT_FOUND"; exit 1
fi

load_language

[[ "$backend" != "pacman" && "$EUID" -eq 0 ]] && err05

## !JAY UPDATE CHECKER

get_upd() {
    local check_cmd="$backend"
    [[ "$aur_helper" != "none" ]] && check_cmd="$aur_helper"
    if $check_cmd -Qua 2>/dev/null | grep -qi "jay-bin"; then
        echo -e "$MSG_JAY_UPD_FOUND"
    fi
}
get_upd

log_rotate() {
    local max_size=512000
    local log_size
    log_size=$(stat -c%s "$LOG_FILE" 2>/dev/null || echo 0)
    [[ "$log_size" -lt "$max_size" ]] && return
    local log_size_hr
    log_size_hr=$(du -sh "$LOG_FILE" | cut -f1)
    echo -e "\n${YELLOW} $NOTE Log file is getting large ($log_size_hr).${NC}"
    echo -e "${CYAN} $CC ${NC}Archive and rotate? [y/N]"
    read -r -n 1 opt
    echo
    if [[ "$opt" =~ ^(y|Y)$ ]]; then
        mv "$LOG_FILE" "${LOG_FILE}.1"
        touch "$LOG_FILE"
        success "Log rotated. Old log saved as jay.log.1"
    fi
}

display_ver() { echo -e "\njay $ver\n"; }
inform() {
    local version_padded
    printf -v version_padded "v%-6s" "$ver"
    
    echo -e "${BOLD}${CYAN}        __            "
    echo -e "${BOLD}${CYAN}       / /___ ___  __ "
    echo -e "${BOLD}${CYAN}  __  / / __  / / / / "
    echo -e "${BOLD}${CYAN} / /_/ / /_/ / /_/ /  "
    echo -e "${BOLD}${CYAN} \____/\__,_/\__, /   "
    echo -e "${BOLD}${CYAN}  ${version_padded}   /____/    "
    echo -e "\n ${YELLOW}release: ${CYAN}$rc\n ${YELLOW}codename: ${CYAN}'Catupiry'\n ${YELLOW}Made by: ${CYAN}xmlzitos154\n${GREEN} Thanks for using JAY!\n ${NC}"
    exit 0
}

#################################
### START OF COMMANDS SESSION ###
#################################

#################################
### START OF FLATPAK SESSION  ###
#################################

flatpak_only() {
    ! command -v flatpak &>/dev/null && err06
    echo -e "${BOLD}${GREEN} $CC $MSG_USING_FLATPAK${NC}"
    
    case "$action" in
        i|in|ins|install|-i)  flat_cmd="install" ;;
        r|rm|rem|remove|-r)   flat_cmd="uninstall" ;;
        u|up|upd|update|-u)   flat_cmd="update" ;;
        s|sr|src|search|-s)   flat_cmd="search" ;;
        q|qr|qur|query|-q)    flat_cmd="list" ;;
        c|cc|cac|cache|-c)    flat_cmd="uninstall --unused" ;;
        cu|check|--check-updates) flat_cmd="remote-ls --updates" ;;
        
        *) error "$MSG_FLAT_NOT_SUP" ;;
    esac
    
    if [[ "$dry_run" == "true" ]]; then
        echo -e "\n${YELLOW}$MSG_DRY_FLATPAK${NC}"
        echo -e "${CYAN}$MSG_DRY_RUN_RUN${NC} flatpak $flat_cmd ${final_args[*]}"
        echo -e "${GREEN}$MSG_DRY_RUN_NONE${NC}\n"
        exit 0
    fi
    
    flatpak $flat_cmd "${final_args[@]}"
    exit_code=$?
    tag="FLATPAK_ONLY"
    logger "$tag" "$flat_cmd ${final_args[*]}"
    exit $exit_code
}

run_flatpak() {
    if [[ "$dry_run" == "true" ]]; then
        echo -e "\n${YELLOW}$MSG_DRY_FLATPAK${NC}"
        echo -e "${CYAN}$MSG_DRY_RUN_RUN${NC} flatpak $flat_cmd ${final_args[*]}"
        echo -e "${GREEN}$MSG_DRY_RUN_NONE${NC}\n"
        exit 0
    fi
    
    [[ "$use_flatpak" != "true" ]] && return
    command -v flatpak &>/dev/null || err06
    case "$action" in
        update|-u)
            step "Updating Flatpaks..."
            flatpak update -y 2>&1 | tee -a "$tmp_out"
            flat_exit=${PIPESTATUS[0]}
            if [[ $flat_exit -eq 0 ]]; then
                logger "UPDATED (flatpak)" "${raw_cmd}"
            fi
            exit_code=$flat_exit
        ;;
        search|-s)
            [[ -n "$flat_cmd" ]] && step "Searching in Flatpak..." && flatpak "$flat_cmd" "${final_args[@]}"
        ;;
        *)
            step "$MSG_USING_FLATPAK"
            flatpak "$flat_cmd" -y "${final_args[@]}"
            exit_code=$?
            [[ $exit_code -eq 0 ]] && tag="FLATPAK"
        ;;
    esac
}
#################################
###  END OF FLATPAK SESSION   ###
#################################

#! NETWORK TESTER
tester() {
    step "$MSG_NET_TEST"
    
    ping -c 2 -i 0.2 8.8.8.8 &>/dev/null &
    local pid=$!
    
    local spin='-\|/'
    while kill -0 $pid 2>/dev/null; do
        local i=$(( (i+1)%4 ))
        printf "\r${CYAN} [%c] Aguardando resposta...\033[K${NC}" "${spin:$i:1}"
        sleep 0.1
    done
    printf "\r\033[K"
    
    if wait $pid; then
        success "$MSG_NET_OK"
    else
        echo -e "${RED}$ERROR \033[K${NC}$MSG_NET_ERR"
        logger "ERROR" "NETWORK" "Rede indisponível"
        exit 1
    fi
}
## !BASE
help_message() {
    display_ver
    echo -e "$HLP_USAGE: jay [command] [options] [packages]"
    echo -e "$HLP_USAGE: jay [-i | -r | -s | -u | check] [-f | --flatpak] [--noconfirm]"
    echo -e "$HLP_USAGE: jay [-q | query] [--list-aur] [--path-to-binary]"
    echo -e "$HLP_USAGE: jay [--restore-backup] [--path /path/to/backup/file.txt]"
    echo -e "$HLP_USAGE: jay [--backend] [yay | paru]"
    echo -e "$HLP_USAGE: jay [slog|-sl] [--lines X]"
    echo -e "\n$HLP_OPTIONS:\n"
    echo -e "-h, --help               $HLP_HELP"
    echo -e "-v, --version            $HLP_VERSION"
    echo -e "-i, install              $HLP_INSTALL"
    echo -e "-r, remove               $HLP_REMOVE"
    echo -e "-u, update               $HLP_UPDATE"
    echo -e "-s, search               $HLP_SEARCH"
    echo -e "-q, query                $HLP_QUERY"
    echo -e "-o, orphan               $HLP_ORPHAN"
    echo -e "-c, cache                $HLP_CACHE"
    echo -e "-m, mirrors              $HLP_MIRRORS"
    echo -e "dp, why                  $HLP_WHY"
    echo -e "snap, --create-snapshot  $HLP_SNAP"
    echo -e "pin, --ignore            $HLP_PIN"
    echo -e "--check-updates          $HLP_CHECK_UPD"
    echo -e "--info                   $HLP_INFO"
    echo -e "--fix-keys               $HLP_FIX_KEYS"
    echo -e "--pacdiff                $HLP_PACDIFF"
    echo -e "--create-backup          $HLP_CREATE_BKp"
    echo -e "--restore-backup         $HLP_RESTORE_BKp"
    echo -e "--path-to-binary         $HLP_PATH_BIN"
    echo -e "--ping                   $HLP_PING"
    echo -e "--lines                  $HLP_LINES"
    echo -e "--view                   $HLP_VIEW"
    echo -e "--dry-run                $HLP_DRY"
    echo -e "--statistics, stats      $HLP_STATS"
    echo -e "--flatpak-only           $HLP_FLAT_ONLY"
    echo -e "--backend                $HLP_BACKEND\n"
    exit 0
}

ins() {
    tester
    cmd="-S"
    tag="INSTALLED"
    flat_cmd="install"
}

rmv() {
    cmd=$([[ "$agressive_mode" == "true" ]] && echo "-Rsn" || echo "-Rs")
    tag=$([[ "$agressive_mode" == "true" ]] && echo "REMOVED WITH -Rsn MODE" || echo "REMOVED")
    flat_cmd="uninstall"
}

upd() {
    tester
    create_snapshot
    cmd="-Syu"
    tag="UPDATED"
    flat_cmd="update"
}

## !CACHE
cache_mgr() {
    local cache_dir="$REAL_HOME/.cache/$backend"
    if [[ -d "$cache_dir" ]]; then
        step "Cleaning $backend builds..."
        find "$cache_dir" -maxdepth 1 -type d -not -path "$cache_dir" -exec rm -rf {} +
        success "Builds cleaned."
    fi
    if command -v flatpak &>/dev/null; then
        step "Cleaning unused Flatpaks..."
        flatpak uninstall --unused -y &>/dev/null
        success "Flatpaks cleaned."
    fi
    step "Cleaning pacman cache..."
    cmd="-Sc"
    tag="CLEANED CACHE"
}

remove_orphans() {
    step "Searching for orphan packages..."
    mapfile -t final_args < <("$backend" -Qqtd 2>/dev/null)
    orphans_n=${#final_args[@]}
    if [[ "$orphans_n" -eq 0 ]]; then
        success "No orphan packages found"
        logger "SEARCHED ORPHANS" "clean"
        exit 0
    fi
    echo "$NOTE $orphans_n Orphans found"
    printf '%s\n' "${final_args[@]}"
    step "Removing orphans..."
    cmd="-Rsn"
    tag="REMOVED ORPHANS"
}

check_conf() {
    step "Searching for .pacnew/.pacsave files..."
    pacnews=$(find /etc -regextype posix-extended -regex ".+\.pac(new|save)" 2>/dev/null)
    if [[ -z "$pacnews" ]]; then
        success "All clear! No conflicts found in /etc."
    else
        echo -e "${YELLOW} $NOTE Pending files found:${NC}"
        echo "$pacnews"
        echo -e "\n${CYAN} $CC ${NC}Merge now with pacdiff? [y/N]"
        read -r -n 1 opt
        echo
        [[ "$opt" =~ ^(y|Y)$ ]] && sudo pacdiff
    fi
    tag="CLEAR DIFFS"
}

## !ETC
create_snapshot() {
    if [[ "$dry_run" == "true" ]]; then
        echo -e "${CYAN}[DRY RUN] Would run:${NC} sudo timeshift --create --comments \"JAY Auto-Snapshot\" --tags D"
        return
    fi
    
    step "$MSG_SNAP_CHECK"
    if command -v timeshift &>/dev/null; then
        step "$MSG_SNAP_CREATING"
        sudo timeshift --create --comments "JAY Auto-Snapshot before update" --tags D
        if [[ $? -eq 0 ]]; then
            success "$MSG_SNAP_SUCCESS"
        else
            echo -e "${YELLOW} $NOTE Warning: Snapshot backup failed, but continuing update...${NC}"
        fi
    else
        echo -e "${YELLOW} $NOTE $MSG_SNAP_NOT_FOUND${NC}"
    fi
}

pin() {
    local pkg="${final_args[0]}"
    local conf="/etc/pacman.conf"
    [[ -z "$pkg" ]] && error "specify a package"
    
    local current
    current=$(grep -oP '(?<=^IgnorePkg = ).*' "$conf")
    
    if echo "$current" | grep -qw "$pkg"; then
        local new
        new=$(echo "$current" | sed "s/\b$pkg\b//" | tr -s ' ' | sed 's/^ //;s/ $//')
        sudo sed -i "s/^IgnorePkg = .*/IgnorePkg = $new/" "$conf"
        success "$pkg unpinned."
        logger "UNPIN" "$pkg"
        elif grep -q "^IgnorePkg" "$conf"; then
        sudo sed -i "s/^IgnorePkg = .*/IgnorePkg = $current $pkg/" "$conf"
        success "$pkg pinned."
        logger "PIN" "$pkg"
        elif grep -q "^#IgnorePkg" "$conf"; then
        sudo sed -i "s/^#IgnorePkg.*/IgnorePkg = $pkg/" "$conf"
        success "$pkg pinned."
        logger "PIN" "$pkg"
    else
        sudo sed -i "/^\[options\]/a IgnorePkg = $pkg" "$conf"
        success "$pkg pinned."
        logger "PIN" "$pkg"
    fi
}
depends() {
    ! command -v pactree &>/dev/null && { step "$MSG_INSTALL_CONTRIB pacman-contrib..."; "$backend" -S pacman-contrib --noconfirm; }
    local pkg="${final_args[0]}"
    [[ -z "$pkg" ]] && echo -e "$ALERT specify a package" && exit 1
    ! pacman -Qi "$pkg" &>/dev/null && echo -e "$ERROR ${YELLOW}Package not found: '$pkg'" && exit 1
    step "Checking reverse dependencies for '$pkg'..."
    local deps_n
    local deps
    deps=$(pactree -r "$pkg" 2>/dev/null | tail -n +2)
    deps_n=$(echo "$deps" | wc -l)
    if [[ -z "$deps" ]]; then
        success "No dependencies found for $pkg."
        logger "WHY" "$pkg -> No dependencies"
        exit 0
    fi
    echo -e "\n $NOTE $deps_n dependencies found"
    echo -e "${YELLOW} $CC '$pkg' is required by:${NC}"
    echo "$deps" | sed 's/^/  /'
    echo -e "\n${CYAN} $NOTE Suggested removal order:${NC}"
    local pkgs
    pkgs=$(echo "$deps" | grep -oP '[\w][\w.+@-]+' | awk '!seen[$0]++' | tr '\n' ' ')
    echo "  jay -r $pkgs"
    logger "WHY" "$pkg"
}

show_stats() {
    step "Gathering system statistics..."
    local native_pkgs=$(pacman -Qn | wc -l)
    local aur_pkgs=$(pacman -Qm | wc -l)
    local flat_pkgs=0
    if command -v flatpak &>/dev/null; then
        flat_pkgs=$(flatpak list --app | wc -l)
    fi
    local cache_size=$(du -sh /var/lib/pacman | cut -f1)
    local install_date=$(head -n1 /var/log/pacman.log | cut -d' ' -f1 | tr -d '[]' | cut -d'T' -f1)
    local aur_cache_size="0"
    [[ -d "$REAL_HOME/.cache/$backend" ]] && aur_cache_size=$(du -sh "$REAL_HOME/.cache/$backend" | cut -f1)
    echo -e "\n${YELLOW}--- JAY SYSTEM STATS ---${NC}"
    echo -e "${GREEN}Packages:${NC}"
    echo -e "  $CC Native: $native_pkgs"
    echo -e "  $CC AUR:    $aur_pkgs"
    [[ $flat_pkgs -gt 0 ]] && echo -e "  $CC Flatpak: $flat_pkgs"
    echo -e "\n${CYAN}Disk Usage (Cache):${NC}"
    echo -e "  $CC Pacman DB: $cache_size"
    echo -e "  $CC System Born on: $install_date"
    echo -e "  $CC $backend Cache: $aur_cache_size"
    if command -v expac &>/dev/null; then
        echo -e "\n${YELLOW}Top 10 Heaviest Packages:${NC}"
        expac "%m %n" | sort -rn | head -10 | awk '{printf "  %s MB\t%s\n", $1/1024/1024, $2}'
    else
        echo -e "\n${YELLOW}$NOTE Install 'expac' to see heaviest packages.${NC}"
    fi
    echo -e "${CYAN}------------------------${NC}"
    tag="STATS"
}

view_pkgbuild() {
    local pkg="$1"
    [[ -z $pkg ]] && echo "$NOTE Specify one package." && exit 1
    step "Searching PKGBUILD for $pkg..."
    local content
    content=$("$backend" -Gp "$pkg" 2>/dev/null)
    if [[ -n "$content" ]]; then
        echo -e "${CYAN}--- PKGBUILD: $pkg ---${NC}\n"
        echo "$content" | less -R
        tag="VIEW PKGBUILD"
    else
        error "Can't find PKGBUILD for '$pkg'. Is it in the AUR?"
    fi
}

list_aur() {
    step "Filtering packages installed via AUR..."
    "$backend" -Qqm | column -t
    tag="LOCAL_QUERY (AUR)"
    local count=$("$backend" -Qqm | wc -l)
    echo -e "\n${GREEN}$COMPLETE${NC} Total of $count AUR packages found."
}

detect_country() {
    mirror_country="$(curl -s --max-time 2 https://ipinfo.io/country 2>/dev/null)"
}

refresh_mirrors() {
    step "Starting mirror optimization (Reflector)..."
    if ! command -v reflector &>/dev/null; then
        echo -e "${YELLOW}$NOTE Reflector not found.${NC}"
        read -p "Do you want to install reflector to optimize mirrors? [Y/n] " -n 1 -r
        if [[ "$REPLY" =~ ^[Yy]$ || -z "$REPLY" ]]; then
            sudo pacman -S reflector --noconfirm
        else
            error "Reflector is required for this function."
        fi
    fi
    
    detect_country
    reflector_args=(--latest 20 --protocol https --sort rate)
    if [[ -n "$mirror_country" ]]; then
        step "Using mirrors from: $mirror_country"
        reflector_args+=(--country "$mirror_country")
    else
        step "Could not detect country, using worldwide mirrors"
    fi
    step "Creating backup at /etc/pacman.d/mirrorlist.bak"
    sudo cp /etc/pacman.d/mirrorlist /etc/pacman.d/mirrorlist.bak
    step "Fetching the fastest mirrors... (Please wait)"
    if sudo reflector "${reflector_args[@]}" --save /etc/pacman.d/mirrorlist; then
        success "Mirrors updated and saved successfully."
        tag="UPDATE MIRRORS"
    else
        error "Failed to update mirrors. Check your internet connection."
    fi
}

fix_keys() {
    step "Starting GPG key recovery..."
    "$backend" -S archlinux-keyring --noconfirm --needed 2>&1 | tee "$tmp_out"
    if [[ -f "$tmp_out" ]]; then
        local keys=$(grep -oP '(?<=key\s)([A-F0-9]{16,})|(?<=ID\s)([A-F0-9]{16,})' "$tmp_out" | sort -u)
        if [[ -n "$keys" ]]; then
            for key in $keys; do
                step "Importing key: $key"
                gpg --recv-keys "$key" || gpg --keyserver hkp://keyserver.ubuntu.com:80 --recv-keys "$key"
            done
        fi
    fi
    step "Cleaning corrupted key caches..."
    sudo find /etc/pacman.d/gnupg -type f -name "*.lck" -delete
    sudo pacman-key --init
    sudo pacman-key --populate archlinux
    success "Done."
}

backup_func() {
    case "$backup_action" in
        "create")
            step "Creating backup of packages..."
            mkdir -p "$BACKUP_DIR"
            "$backend" -Qqa > "$BACKUP_FILE"
            checksum=$(sha256sum "$BACKUP_FILE" | cut -d' ' -f1)
            echo "$checksum" > "$BACKUP_DIR/backup.sha256"
            success "Backup created successfully in $BACKUP_FILE"
            logger "CREATED BACKUP" "$BACKUP_FILE"
            exit 0
        ;;
        "restore")
            [[ -n "$custom_path" ]] && BACKUP_FILE="$custom_path"
            if [[ ! -f "$BACKUP_FILE" ]]; then
                error "Backup file not found."
            fi
            local backup_base="${BACKUP_FILE%.*}"
            checksum_file="${backup_base}.sha256"
            if [[ ! -f "$checksum_file" ]]; then
                error "Validation key not found. Backup may be invalid or corrupted."
            fi
            step "Validating backup integrity..."
            local stored_hash
            stored_hash=$(cat "$checksum_file")
            local actual_hash
            actual_hash=$(sha256sum "$BACKUP_FILE" | cut -d' ' -f1)
            if [[ "$stored_hash" != "$actual_hash" ]]; then
                error "Backup validation failed. File may be corrupted or tampered."
            fi
            success "Backup integrity verified."
            step "Restoring backup..."
            mapfile -t pkg_list < "$BACKUP_FILE"
            if "$backend" -S "${pkg_list[@]}" --needed; then
                success "Backup restored."
                logger "BACKUP RESTORATION" "Reinstalled ${#pkg_list[@]} packages"
                exit 0
            else
                error "Restore failed."
            fi
        ;;
    esac
}

## !LOG_MANAGER
sl() {
    [[ ! -s "$LOG_FILE" ]] && echo "$NOTE The log file is empty." && exit 0
    if [[ -n "$log_lines" && "$log_lines" =~ ^[0-9]+$ ]]; then
        tail -n "$log_lines" "$LOG_FILE"
    else
        cat "$LOG_FILE"
    fi
}

cl() {
    [[ ! -s "$LOG_FILE" ]] && echo "$NOTE The log file is empty." && exit 0
    echo "" > "$LOG_FILE"
    success "Done."
}

logger() {
    local status="${exit_code:-0}"
    local tag="$1"
    local info="$2"
    printf -v date_str '%(%Y-%m-%d - %H:%M:%S)T' -1
    echo "$date_str [Exit Status $status] [$tag] -> $info" >> "$LOG_FILE"
}

## !SEARCH
searcher() {
    tester
    cmd="-Ss"
    tag="SEARCHED"
    flat_cmd="search"
}

query() {
    cmd="-Qs"
    tag="LOCAL QUERY"
    [[ "$ptbin" == true ]] && get_package_path "${final_args[@]}" && tag="SKIP" && return
}

check_updates() {
    tester
    command -v checkupdates &>/dev/null || { step "Installing dependencies..."; "$backend" -S pacman-contrib --noconfirm; }
    step "Searching for updates..."
    local tmp_repo=$(mktemp)
    local tmp_aur=$(mktemp)
    checkupdates > "$tmp_repo" 2>/dev/null &
    local pid_repo=$!
    "$backend" -Qua > "$tmp_aur" 2>/dev/null &
    local pid_aur=$!
    local pid_flat=""
    local tmp_flat=""
    if [[ "$use_flatpak" == "true" ]] && command -v flatpak &>/dev/null; then
        tmp_flat=$(mktemp)
        flatpak remote-ls --updates > "$tmp_flat" 2>/dev/null &
        pid_flat=$!
    fi
    wait $pid_repo $pid_aur ${pid_flat:+$pid_flat}
    local upds_n=$(wc -l < "$tmp_repo")
    local upds_aur_n=$(wc -l < "$tmp_aur")
    local upds_flat_n=0
    [[ -f "$tmp_flat" ]] && upds_flat_n=$(wc -l < "$tmp_flat")
    local total=$((upds_n + upds_aur_n + upds_flat_n))
    if [[ "$total" -eq 0 ]]; then
        success "Your system is updated."
        rm -f "$tmp_repo" "$tmp_aur" ${tmp_flat:+"$tmp_flat"}
        return
    fi
    local flat_info=""
    [[ "$use_flatpak" == "true" ]] && flat_info=" and $upds_flat_n in Flatpak"
    echo -e "${YELLOW} $NOTE $total Updates found ($upds_aur_n in AUR$flat_info):${NC}"
    [[ "$upds_n" -gt 0 ]] && echo -e "\nOfficial upds:\n${CYAN}$(cat "$tmp_repo")${NC}"
    [[ "$upds_aur_n" -gt 0 ]] && echo -e "\nUpdates in AUR:\n${GREEN}$(cat "$tmp_aur")${NC}"
    if [[ "$use_flatpak" == "true" && "$upds_flat_n" -gt 0 ]]; then
        echo -e "\nUpdates in Flatpak:\n${YELLOW}$(cat "$tmp_flat")${NC}"
    fi
    rm -f "$tmp_repo" "$tmp_aur" ${tmp_flat:+"$tmp_flat"}
    logger "FOUND UPDATES" "$total updates (Flatpak: $use_flatpak)"
}

get_package_path() {
    local pkg="$1"
    local bins=$(pacman -Ql "$pkg" 2>/dev/null | awk '/\/bin\// {print $2}')
    if [[ -n "$bins" ]]; then
        echo -e "${GREEN}Binaries found:${NC}\n$bins"
    else
        step "No binaries found in $pkg"
    fi
}

###############################
### END OF COMMANDS SESSION ###
###############################

[[ -f "$LOG_FILE" ]] || touch "$LOG_FILE"
[[ ! -w "$LOG_FILE" ]] && sudo chown "${SUDO_USER:-$USER}":"${SUDO_USER:-$USER}" "$LOG_FILE" 2>/dev/null
[[ -z "$1" ]] && usage

raw_cmd="$*"; use_flatpak=false; ptbin=false; agressive_mode=false; final_args=(); yay_flags=(); log_lines=""; dry_run=false; verbose_mode=false
log_rotate

while [[ $# -gt 0 ]]; do
    case "$1" in
        --create-snapshot|dp|why|--ignore|pin|stats|--list-aur|--pacdiff|--ping|--create-backup|--restore-backup|install|-i|remove|-r|update|-u|search|-s|query|-q|cache|-c|orphan|-o|mirrors|-m|slog|-cl|-sl|--fix-keys|--check-updates)
            [[ -z "$action" ]] && action="$1" || final_args+=("$1")
        ;;
        --view)
            [[ -z "$action" ]] && action="--view" || final_args+=("$1")
        ;;
        --backend)
            shift
            if [[ "$1" == "paru" || "$1" == "yay" || "$1" == "pikaur" ]]; then
                backend="$1"
            else
                err04
            fi
        ;;
        --path)
            shift
            [[ -z "$1" ]] && error "--path requires a file path argument"
            custom_path="$1"
        ;;
        --lines)
            shift
            log_lines="$1"
        ;;
        -h|--help) help_message ;;
        --info) inform; exit 0 ;;
        -f|--flatpak) use_flatpak=true ;;
        --flatpak-only) only_flatpak=true ;;
        -v|--version) display_ver; exit 0 ;;
        -A) agressive_mode=true ;;
        --path-to-binary) ptbin=true ;;
        --dry-run) dry_run=true ;;
        nc|--noconfirm) yay_flags+=("--noconfirm") ;;
        -) action="-" && err01 ;;
        -*) action="$1" && err01 ;;
        *) final_args+=("$1") ;;
    esac
    shift
done

[[ -z "$action" && ${#final_args[@]} -gt 0 ]] && action="${final_args[0]}" && final_args=("${final_args[@]:1}")

[[ "$action" =~ ^(install|remove|-i|-r)$ && ${#final_args[@]} -eq 0 ]] && error "$MSG_SPECIFY_PKG"

! command -v "$backend" &>/dev/null && err03

tmp_out=$(mktemp) || err02
trap 'rm -f "$tmp_out" 2>/dev/null' EXIT

if [[ -f /var/lib/pacman/db.lck ]]; then
    { pgrep -x pacman >/dev/null || pgrep -x "$backend" >/dev/null; } && error "$MSG_PACMAN_RUNNING"
    sudo rm /var/lib/pacman/db.lck && success "$MSG_LOCK_REMOVED"
fi

if [[ -n "$action" ]]; then
    [[ "$agressive_mode" == "true" ]] && echo -e "${RED} $NOTE $MSG_AGRESSIVE_MODE${NC}"
fi

[[ "$only_flatpak" == "true" ]] && flatpak_only

case "$action" in
    show-logs|slog|-sl) sl ;;
    clear-logs|clog|-cl) cl ;;
    --ping) tester && logger "TEST FOR NETWORK" "available" && exit 0 ;;
    snap|--create-snapshot) create_snapshot ;;
    i|in|ins|install|-i) ins ;;
    r|rm|rem|remove|-r|-rm) rmv ;;
    u|up|upd|update|-u) upd ;;
    s|sr|src|search|-s) searcher ;;
    q|qr|qur|query|-q) query ;;
    c|cc|cac|cache|-c) cache_mgr ;;
    o|op|orp|orphan|-o) remove_orphans ;;
    m|mr|mir|mirrors|-m) refresh_mirrors ;;
    cu|check|--check-updates) check_updates ;;
    fk|--fix-keys) fix_keys ;;
    pd|--pacdiff) check_conf ;;
    cb|--create-backup) backup_action="create"; backup_func ;;
    rb|--restore-backup) backup_action="restore"; backup_func ;;
    pin|--ignore) pin ;;
    la|--list-aur) list_aur ;;
    dp|why) depends ;;
    vi|--view) view_pkgbuild "${final_args[0]}"; exit 0 ;;
    stats|statistics) show_stats ;;
    *) err01 ;;
esac

[[ "$tag" == "SKIP" ]] && exit 0

if [[ "$dry_run" == "true" ]]; then
    echo -e "\n${YELLOW}$MSG_DRY_RUN_SIM${NC}"
    if [[ -n "$cmd" ]]; then
        echo -e "${CYAN}$MSG_DRY_RUN_RUN${NC} $backend $cmd ${final_args[*]} ${yay_flags[*]}"
    fi
    if [[ "$use_flatpak" == "true" && -n "$flat_cmd" ]]; then
        echo -e "${CYAN}$MSG_DRY_RUN_RUN${NC} flatpak $flat_cmd ${final_args[*]}"
    fi
    echo -e "${GREEN}$MSG_DRY_RUN_NONE${NC}\n"
    exit 0
fi

case "$action" in
    search|-s)
        "$backend" "$cmd" "${final_args[@]}" "${yay_flags[@]}" 2>&1 | tee "$tmp_out"
        exit_code=${PIPESTATUS[0]}
        run_flatpak
    ;;
    *)
        if [[ -n "$cmd" ]]; then
            "$backend" "$cmd" "${final_args[@]}" "${yay_flags[@]}" 2>&1 | tee "$tmp_out"
            exit_code=${PIPESTATUS[0]}
            run_flatpak
        fi
    ;;
esac

if [[ "$exit_code" -eq 0 && -n "$tag" ]]; then
    if grep -qiE "could not find|nenhum pacote|target not found" "$tmp_out"; then
        logger "NOT FOUND" "${raw_cmd}"
    else
        logger "${tag:-SYSTEM}" "${raw_cmd}"
    fi
fi