            HLP_CACHE="Clear all pacman cache"
            HLP_MIRRORS="Search for faster repos"
            HLP_WHY="List dependencies of specified package"
            HLP_SNAP="Create a snapshot of the actual system state (automatic for updates)"
            HLP_PIN="Ignore specified packages in updates"
            HLP_CHECK_UPD="Search for available updates"
            HLP_INFO="Show more detailed informations of this program"
            HLP_FIX_KEYS="Restore invalid GPG keys"
            HLP_PACDIFF="Manage pacdiffs"
            HLP_CREATE_BKp="Create a backup file"
            HLP_RESTORE_BKp="Install packages listed on backup file"
            HLP_PATH_BIN="Search for binary path (use with query)"
            HLP_PING="Test if network is available"
            HLP_LINES="Specify number of lines to display on -sl/slog command"
            HLP_VIEW="View PKGBUILD file of AUR Packages"
            HLP_DRY="Show what the command will do instead of actually execute them"
            HLP_STATS="Show packages and system statistics"
            HLP_FLAT_ONLY="Use flatpak as backend"
            HLP_BACKEND="Switches the aur helper between yay and paru to be used (Default: yay)"
            MSG_ERR01="invalid argument"
            MSG_ERR02="Cannot create temporary file"
            MSG_ERR03="the specified AUR Helper ($backend) not found"
            MSG_ERR04="Specified aur helper is not found or is not supported."
            MSG_ERR05="Don't use '$backend' with sudo."
            MSG_ERR06="Flatpak is not installed."
            MSG_ERR07="Pacman needs sudo to continue."
            MSG_JAY_UPD_FOUND="${YELLOW}${BOLD}$NOTE A new update for JAY was found! Install it using: jay -u${NC}"
            MSG_AUR_HELPER_NOT_FOUND="$ERROR Not found availables AUR helpers"
            MSG_LARGE_LOG_FILE="The log file is getting larger."
            MSG_AUR_HELPER_NOT_FOUND="No AUR Helpers found, using pacman (limited)."
            MSG_EMPTY_LOG="The log file is empty."
            MSG_WAITING="Waiting for response"
        ;;
    esac
}

load_language

## !FUNCTIONS

step() { echo -e "${BOLD}${GREEN}$CC ${1}${NC}"; }
success() { echo -e "${GREEN} $COMPLETE ${NC}${1}"; }
error() { echo -e "${RED} $ERROR ${NC}${1}"; exit 1; }

err01() { echo -e "$ALERT $MSG_ERR01 '$action'"; exit 1; }
err02() { echo -e "${RED}$ERROR $MSG_ERR02"; exit 1; }
err03() { echo -e "${RED}$ERROR $MSG_ERR03"; exit 1; }
err04() { echo -e "${RED}$ERROR $MSG_ERR04"; exit 1; }
err05() { echo -e "${RED}$ERROR $MSG_ERR05"; exit 1; }
err06() { echo -e "${RED}$ERROR $MSG_ERR06"; exit 1; }
err07() { echo -e "${RED}$ERROR $MSG_ERR07"; exit 1; }
usage() { echo -e "$HLP_USAGE: jay [$USG1] [$USG2] [$USG3]"; exit 1; }

if command -v yay &>/dev/null; then
    echo -e "${GREEN}${BOLD}$CC $MSG_USING_BACKEND yay...${NC}"
    backend="yay"
    elif command -v paru &>/dev/null; then
    echo -e " ${CYAN}${BOLD}$NOTE paru $MSG_DETECTED paru...${NC}"
    backend="paru"
    elif command -v pikaur &>/dev/null; then
    echo -e " ${CYAN}${BOLD}$NOTE pikaur $MSG_DETECTED pikaur...${NC}"
    backend="pikaur"
else
    echo -e "${YELLOW}${BOLD}$MSG_AUR_HELPER_NOT_FOUND"
    backend="pacman"
fi

load_language

[[ "$backend" == "pacman" && "$EUID" -ne 0 ]] && err07
[[ "$backend" != "pacman" && "$EUID" -eq 0 ]] && err05

## !JAY UPDATE CHECKER

get_upd() {
    if "$backend" -Qua 2>/dev/null | grep -qi "jay-bin"; then
        echo -e "$MSG_JAY_UPD_FOUND"
    fi
}

get_upd

log_rotate() {
    local max_size=512000
    local log_size
    log_size=$(stat -c%s "$LOG_FILE" 2>/dev/null || echo 0)
    [[ "$log_size" -lt "$max_size" ]] && return
    local log_size_hr
    log_size_hr=$(du -sh "$LOG_FILE" | cut -f1)
    echo -e "\n${YELLOW} $NOTE $MSG_LARGE_LOG_FILE ($log_size_hr).${NC}"
    echo -e -n "${CYAN} $CC ${NC}$ASK_ROTATE? [$ASK_1/$ASK_2]"
    read -r -n 1 opt
    echo
    if [[ "$opt" =~ ^(y|Y|s|S)$ ]]; then
        mv "$LOG_FILE" "${LOG_FILE}.1"
        touch "$LOG_FILE"
        success "$MSG_ROTATED jay.log.1"
    fi
}

display_ver() { echo -e "\njay $ver\n"; }
inform() {
    local version_padded
    printf -v version_padded "v%-6s" "$ver"
    
    echo -e "${BOLD}${CYAN}        __            "
    echo -e "${BOLD}${CYAN}       / /___ ___  __ "
    echo -e "${BOLD}${CYAN}  __  / / __  / / / / "
    echo -e "${BOLD}${CYAN} / /_/ / /_/ / /_/ /  "
    echo -e "${BOLD}${CYAN} \____/\__,_/\__, /   "
    echo -e "${BOLD}${CYAN}  ${version_padded}   /____/    "
    echo -e "\n ${YELLOW}$MSG_RELEASE ${CYAN}$rc\n ${YELLOW}$MSG_CODENAME ${CYAN}'Catupiry'\n ${YELLOW}$MSG_MADE_BY ${CYAN}xmlzitos154\n${GREEN} $MSG_THANKS\n ${NC}"
    exit 0
}

flatpak_only() {
    ! command -v flatpak &>/dev/null && err06
    echo -e "${BOLD}${GREEN} $CC $MSG_USING_FLATPAK${NC}"
    
    case "$action" in
        i|in|ins|install|-i)  flat_cmd="install" ;;
        r|rm|rem|remove|-r)   flat_cmd="uninstall" ;;
        u|up|upd|update|-u)   flat_cmd="update" ;;
        s|sr|src|search|-s)   flat_cmd="search" ;;
        q|qr|qur|query|-q)    flat_cmd="list" ;;
        c|cc|cac|cache|-c)    flat_cmd="uninstall --unused" ;;
        cu|check|--check-updates) flat_cmd="remote-ls --updates" ;;
        
        *) error "$MSG_FLAT_NOT_SUP" ;;
    esac
    
    if [[ "$dry_run" == "true" ]]; then
        echo -e "\n${YELLOW}$MSG_DRY_FLATPAK${NC}"
        echo -e "${CYAN}$MSG_DRY_RUN_RUN${NC} flatpak $flat_cmd ${final_args[*]}"
        echo -e "${GREEN}$MSG_DRY_RUN_NONE${NC}\n"
        exit 0
    fi
    
    flatpak $flat_cmd "${final_args[@]}"
    exit_code=$?
    tag="FLATPAK_ONLY"
    logger "$tag" "$flat_cmd ${final_args[*]}"
    exit $exit_code
}

run_flatpak() {
    if [[ "$dry_run" == "true" ]];
    then
        echo -e "\n${YELLOW}$MSG_DRY_FLATPAK${NC}"
        echo -e "${CYAN}$MSG_DRY_RUN_RUN${NC} flatpak $flat_cmd ${final_args[*]}"
        echo -e "${GREEN}$MSG_DRY_RUN_NONE${NC}\n"
        exit 0
    fi
    
    [[ "$use_flatpak" != "true" ]] && return
    command -v flatpak &>/dev/null || err06
    case "$action" in
        update|-u)
            step "$MSG_FLAT_UPDATING"
            flatpak update -y 2>&1 | tee -a "$tmp_out"
            flat_exit=${PIPESTATUS[0]}
            if [[ $flat_exit -eq 0 ]];
            then
                logger "UPDATED (flatpak)" "${raw_cmd}"
            fi
            exit_code=$flat_exit
        ;;
        search|-s)
            [[ -n "$flat_cmd" ]] && step "$MSG_FLAT_SEARCHING" && flatpak "$flat_cmd" "${final_args[@]}"
        ;;
        *)
            step "$MSG_USING_FLATPAK"
            flatpak "$flat_cmd" -y "${final_args[@]}"
            exit_code=$?
            [[ $exit_code -eq 0 ]] && tag="FLATPAK"
        ;;
    esac
}

#! NETWORK TESTER
tester() {
    step "$MSG_NET_TEST"
    
    ping -c 2 -i 0.2 8.8.8.8 &>/dev/null &
    local pid=$!
    
    local spin='-\|/'
    while kill -0 $pid 2>/dev/null; do
        local i=$(( (i+1)%4 ))
        printf "\r${CYAN} [%c] $MSG_WAITING...\033[K${NC}" "${spin:$i:1}"
        sleep 0.1
    done
    printf "\r\033[K"
    
    if wait $pid; then
        success "$MSG_NET_OK"
    else
        echo -e "${RED}$ERROR \033[K${NC}$MSG_NET_ERR"
        logger "ERROR" "NETWORK" "Unavailable network"
        exit 1
    fi
}

