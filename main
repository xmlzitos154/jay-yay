#!/usr/bin/env bash

VER="2.8 (Yogourt)"

REAL_HOME=$(getent passwd "$SUDO_USER" | cut -d: -f6)
REAL_HOME=${REAL_HOME:-$HOME}

MODULES_DIR="$REAL_HOME/.config/jay/modules"
LOG_FILE="$REAL_HOME/.cache/jaylog.txt"
CONFIG_DIR="$REAL_HOME/.config/jay"

CYAN='\033[0;36m'
GREEN='\033[0;32m'
YELLOW='\033[1;33m'
RED='\033[0;31m'
NC='\033[0m'

ALERT="[!]"
ERROR="[x]"
OK="[✓]"
WARNING="[*]"
CONTINUE=" :: "

err01() {
    echo -e -n "${CYAN} $ALERT ${NC}" && echo "argumento invalido '$VAR'" | tr -d "-"
    exit 1
}

err02() {
    echo -e -n "${CYAN} $ALERT ${NC}" && echo "argumento invalido '-'"
    exit 1
}

err03() {
    echo -e "\n ${CYAN}-> JAY (Just Another Yogourt) - Version $VER ${NC}\n"
}

err04() {
    echo -e "${RED}$ERROR Módulo crítico '$MISSING_MODULE' não encontrado${NC}\n -> saindo com status 1"
    exit 1
}

[[ -f "$LOG_FILE" ]] || touch "$LOG_FILE"

[[ ! -f "$MODULES_DIR/base" ]] && MISSING_MODULE="base" && err04
[[ ! -f "$MODULES_DIR/log" ]] && MISSING_MODULE="log" && err04

source "$MODULES_DIR/base"
source "$MODULES_DIR/log"

[[ -f "$MODULES_DIR/cache" ]] && source "$MODULES_DIR/cache" || MOD_1="false"
[[ -f "$MODULES_DIR/search" ]] && source "$MODULES_DIR/search" || MOD_2="false"
[[ -f "$MODULES_DIR/extra" ]] && source "$MODULES_DIR/extra" || MOD_3="false"

step() { echo -e "${CYAN} $CONTINUE ${NC}${1}"; }
success() { echo -e "${GREEN} $OK ${NC}${1}"; }
error() { echo -e "${RED} $ERROR ${NC}${1}"; exit 1; }

logger() {
    local tag="$1"
    local info="$2"
    local date_str=$(date "+%H:%M - %d/%m/%Y")
    echo "($date_str) | $tag | $info" >> "$LOG_FILE"
}

help_message() {
    err03
    echo -e "Uso: jay [comando] [opções] [pacotes]"
    echo -e "Uso: jay [ -i | -rm | -s | -u ] [ -f | --flatpak ] [ --noconfirm ]"
    echo -e "Uso: jay [ -q | query ] [ --list-aur ]"
    echo -e "Options: \n"\
    echo -e "-h,  --help         Mostra essa mensagem"
    echo -e "-i,  install        Sincronizar pacotes"
    echo -e "-rm, remove         Remover pacotes (Use '-A' para modo Agressivo)"
    echo -e "-u,  update         Atualizar o sistema"
    if [[ "$MOD_2" != "false" ]]; then
        echo -e "-s,  search         Pesquisa pacotes no AUR"
        echo -e "-q,  query          Pesquisa pacotes locais"
    fi
    if [[ "$MOD_1" != "false" ]]; then
        echo -e "-o,  orphan         Remove dependências inúteis"
        echo -e "-c,  cache          Limpa todo o cache do pacman"
        echo -e "-d,  --diff         Gerencia arquivos .pacnew/.pacsave"
    fi
    if [[ "$MOD_3" != "false" ]]; then
        echo -e "-m, mirrors         Procura repositorios velozes"
        echo -e "-M, modules         Mostra os modulos disponiveis"
        echo -e "--check-updates     Procura Atualizações Disponiveis"
    fi
    exit 0
}

usage() {
    echo -e "${RED} $ERROR Uso: jay <comando> <pacotes>${NC}"
    exit 1
}

[[ -z "$1" ]] && usage
RAW_CMD="$*"

USE_FLATPAK=false ; AGRESSIVE_MODE=false ; FINAL_ARGS=() ; YAY_FLAGS=() ; ACTION=""

for arg in "$@"; do
    case "$arg" in
        install|-i|-S|remove|-rm|update|-u|search|-s|query|-q|cache|-c|orphan|-o|mirrors|-m|refresh|-r|slog|-sl|clog|-cl|modules|-M|-v|--version|-h|--help|--check-updates|--diff)
        [[ -z "$ACTION" ]] && ACTION="$arg" || FINAL_ARGS+=("$arg") ;;
        -f|--flatpak)
        USE_FLATPAK=true ;;
        -A)
        AGRESSIVE_MODE=true ;;
        --kill-dblck)
            if [[ -f /var/lib/pacman/db.lck ]]; then
                sudo rm /var/lib/pacman/db.lck && success "Trava removida."
        fi ;;
        --list-aur)
        [[ "$ACTION" =~ ^(query|-q)$ ]] && { [[ "$MOD_3" != "false" ]] && list_aur && exit 0 || error "Módulo extra necessário."; } ;;
        -*)
        YAY_FLAGS+=("$arg") ;;
        *)
        FINAL_ARGS+=("$arg") ;;
    esac
done

[[ -z "$ACTION" && ${#FINAL_ARGS[@]} -gt 0 ]] && ACTION="${FINAL_ARGS[0]}" && unset 'FINAL_ARGS[0]'

case "$ACTION" in
    "-") err02 ;;
    install|-i|-S) ins ;;
    remove|-rm) rmv ;;
    refresh|-r) rfs ;;
    update|-u) upd ;;
    slog|-sl) show_logs ; exit 0 ;;
    clog|-cl) clear_logs ; exit 0 ;;
    modules|-M) query_modules ;;
    --diff|-d) [[ "$MOD_1" == "false" ]] && error "Módulo cache necessário." || { check_conf ; exit 0; } ;;
    search|-s) [[ "$MOD_2" == "false" ]] && error "Módulo search necessário." || { searcher "${FINAL_ARGS[@]}"; exit 0; } ;;
    query|-q) [[ "$MOD_2" == "false" ]] && error "Módulo search necessário." || { query "${FINAL_ARGS[@]}"; exit 0; } ;;
    cache|-c) [[ "$MOD_1" == "false" ]] && error "Módulo cache necessário." || { clr_cache ; exit 0; } ;;
    orphan|-o) [[ "$MOD_1" == "false" ]] && error "Módulo cache necessário." || { remove_orphans ; exit 0; } ;;
    mirrors|-m) [[ "$MOD_3" == "false" ]] && error "Módulo extra necessário." || { refresh_mirrors ; exit 0; } ;;
    --check-updates) [[ "$MOD_3" == "false" ]] && error "Módulo extra necessário." || { check_updates ; exit 0; } ;;
    -v|--version) err03; exit 0 ;;
    -h|--help) help_message ;;
    *) VAR="$ACTION" ; err01 ;;
esac

[[ "$ACTION" =~ ^(install|remove|-i|-rm)$ && ${#FINAL_ARGS[@]} -eq 0 ]] && error "Informe ao menos um pacote"
command -v yay &>/dev/null || error "yay não encontrado"
TMP_OUT=$(mktemp)

if [[ -n "$CMD" ]]; then
    [[ "$AGRESSIVE_MODE" == "true" ]] && echo -e "${RED} $ALERT Modo agressivo ativado!${NC}"
    step "Iniciando via AUR..."
    yay "$CMD" "${FINAL_ARGS[@]}" "${YAY_FLAGS[@]}" 2>&1 | tee "$TMP_OUT"
    EXIT_CODE=${PIPESTATUS[0]}
fi

if [[ "$USE_FLATPAK" == "true" ]]; then
    if [[ "$ACTION" =~ ^(update|-u)$ ]]; then
        step "Atualizando Flatpaks..."
        flatpak update -y
        elif [[ $EXIT_CODE -ne 0 ]] || grep -qiE "Nenhum pacote|não há nada|target not found" "$TMP_OUT"; then
        echo -e "\n${YELLOW} $WARNING AUR não resolveu. Tentando Flatpak...${NC}\n"
        if command -v flatpak &>/dev/null; then
            flatpak $FLAT_CMD -y "${FINAL_ARGS[@]}"
            EXIT_CODE=$?
            [[ $EXIT_CODE -eq 0 ]] && TAG=$([[ "$FLAT_CMD" == "uninstall" ]] && echo "[RM FLATPAK]" || echo "[FLATPAK]")
        fi
    fi
fi

if [[ "$TAG" != "SKIP" ]]; then
    if [[ $EXIT_CODE -ne 0 ]]; then
        TAG="$ALERT Erro"
        PKGS_TO_LOG="$RAW_CMD"
        elif [[ "$ACTION" =~ ^(update|-u)$ ]]; then
        PKGS_TO_LOG=$(sed 's/\x1b\[[0-9;]*[mGJK]//g' "$TMP_OUT" | grep -E "upgraded|atualizado" | awk '{print $3}' | tr '\n' ',' | sed 's/,$//')
    else
        PKGS_TO_LOG=$(IFS=','; echo "${FINAL_ARGS[*]}")
    fi
    logger "$TAG" "${PKGS_TO_LOG:-SYSTEM}"
fi

rm -f "$TMP_OUT"
