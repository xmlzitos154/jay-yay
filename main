#!/usr/bin/env bash

ver="5.3.1"; rc="1"

## JAY - A Semantic AUR helper wrapper written in bash

ver_msg() { echo -e "\njay v$ver - rc-$rc\n"; }
inform() { echo -e " -> jay v$ver - release-candidate $rc - version codename 'Ice Cream'"; }

set -o pipefail
REAL_HOME=$(getent passwd "${SUDO_USER:-$USER}" 2>/dev/null | cut -d: -f6); REAL_HOME=${REAL_HOME:-$HOME}
BACKUP_DIR="$REAL_HOME/.local/share/jay/backup"; BACKUP_FILE="$BACKUP_DIR/backup.txt"
LOG_FILE="$REAL_HOME/.cache/jay.log"

CYAN='\033[0;36m'; GREEN='\033[0;32m'; YELLOW='\033[1;33m'; RED='\033[0;31m'; NC='\033[0m';
ALERT="[!]"; ERROR="[x]"; COMPLETE="[✓]"; NOTE="[*]"; CC="::"

step() { echo -e "${CYAN} $CC ${NC}${1}"; }
success() { echo -e "${GREEN} $COMPLETE ${NC}${1}"; }
error() { echo -e "${RED} $ERROR ${NC}${1}"; exit 1; }
err01() { echo -e "$ALERT invalid argument '$ACTION'"; exit 1; }
err02() { echo -e "${RED}$ERROR Cannot create temporary file"; exit 1; }
err03() { echo -e "${RED}$ERROR the specified AUR Helper ($backend) not found"; exit 1; }
err04() { echo -e "${RED}$ERROR Specified aur helper is not found or is not suported."; exit 1; }
err05() { echo -e "${RED}$ERROR Don't use '$backend' with sudo."; exit 1; }
err06() { echo -e "${RED}$ERROR Flatpak is not installed."; exit 1; }
usage() { echo -e "Usage: jay [command] [options] [packages]"; exit 1; }

if command -v yay &>/dev/null; then
    echo -e "${GREEN} $CC ${NC}Using yay..."
    backend="yay"
    elif command -v paru &>/dev/null; then
    echo -e " $NOTE paru detected, using paru..."
    backend="paru"
    elif command -v pikaur &>/dev/null; then
    echo -e " $NOTE pikaur detected, using pikaur..."
    backend="pikaur"
else
    echo -e "${YELLOW} $ALERT No AUR Helpers found. Using pacman instead (limited)${NC}"; backend="pacman"
    [[ ! "$EUID" == "0" ]] && error "Pacman needs sudo to continue."
fi

[[ "$backend" != "pacman" && "$EUID" -eq 0 ]] && err05

#################################
### START OF COMMANDS SESSION ###
#################################

## NETWORK TESTER
tester() {
    step "Testing network..."
    if ping -c 1 -i 0.1 8.8.8.8 &>/dev/null; then
        success "Connection is active."
    else
        echo -e "${RED}$ERROR ${NC}Network disconnected. Verify your Wi-Fi/Cable."
        logger "TEST FOR NETWORK" "unavailable"
        exit 1
    fi
}

## BASE
help_message() {
    ver_msg
    echo -e "Usage: jay [command] [options] [packages]"
    echo -e "Usage: jay [-i | -r | -s | -u | check] [-f | --flatpak] [--noconfirm]"
    echo -e "Usage: jay [-q | query] [--list-aur] [--path-to-binary]"
    echo -e "Usage: jay [--restore-backup] [--path /path/to/backup/file.txt]"
    echo -e "Usage: jay [--backend] [yay | paru]"
    echo -e "Usage: jay [slog|-sl] [--lines LINES_TO_DISPLAY]"
    echo -e "\nOptions:\n"
    echo -e "-h, --help              Show this message again"
    echo -e "-v, --version           Show the actual program version"
    echo -e "-i, install             Sync/install packages"
    echo -e "-r, remove              Remove packages (Use '-A' to activate the Agressive mode)"
    echo -e "-u, update              Update the system"
    echo -e "-s, search              search packages in AUR"
    echo -e "-q, query               Query local packages"
    echo -e "-o, orphan              Remove non-necessary packages"
    echo -e "-c, cache               Clear all pacman cache"
    echo -e "-m, mirrors             Search for faster repos"
    echo -e "--check-updates         Search for available updates"
    echo -e "--info                  Show more detailed informations of this program"
    echo -e "--fix-keys              Restore invalid GPG keys"
    echo -e "--pacdiff               Manage pacdiffs"
    echo -e "--create-backup         Create an backup file"
    echo -e "--restore-backup        Install packages listed on backup file"
    echo -e "--path-to-binary        Search for binary path (use with query)"
    echo -e "--ping                  Test if network is available"
    echo -e "--lines                 Specify number of lines to display on -sl/slog command"
    echo -e "--view                  View PKGBUILD file of AUR Packages"
    echo -e "--statistics, stats     Show packages and system statistics"
    echo -e "--flatpak-only          Use flatpak as backend"
    echo -e "--backend               Switches the aur helper between yay and paru to be used (Default: yay)\n"
    exit 0
}

#################################
### START OF FLATPAK SESSION  ###
#################################

flatpak_only() {
    ! command -v flatpak &>/dev/null && err06
    echo -e "${GREEN} $CC ${NC}Using flatpak..."
    
    case "$ACTION" in
        i|in|ins|install|-i)  FLAT_CMD="install" ;;
        r|rm|rem|remove|-r)   FLAT_CMD="uninstall" ;;
        u|up|upd|update|-u)   FLAT_CMD="update" ;;
        s|sr|src|search|-s)   FLAT_CMD="search" ;;
        q|qr|qur|query|-q)    FLAT_CMD="list" ;;
        c|cc|cac|cache|-c)    FLAT_CMD="uninstall --unused" ;;
        cu|check|--check-updates) FLAT_CMD="remote-ls --updates" ;;
        
        *) error "Action '$ACTION' not supported in Flatpak-only mode." ;;
    esac
    flatpak $FLAT_CMD "${FINAL_ARGS[@]}"
    EXIT_CODE=$?
    TAG="FLATPAK_ONLY"
    logger "$TAG" "$FLAT_CMD ${FINAL_ARGS[*]}"
    exit $EXIT_CODE
}

run_flatpak() {
    [[ "$USE_FLATPAK" != "true" ]] && return
    command -v flatpak &>/dev/null || err06
    case "$ACTION" in
        update|-u)
            step "Updating Flatpaks..."
            flatpak update -y 2>&1 | tee -a "$TMP_OUT"
            FLAT_EXIT=${PIPESTATUS[0]}
            if [[ $FLAT_EXIT -eq 0 ]]; then
                logger "UPDATED (flatpak)" "${RAW_CMD}"
            fi
            EXIT_CODE=$FLAT_EXIT
        ;;
        search|-s)
            [[ -n "$FLAT_CMD" ]] && step "Searching in Flatpak..." && flatpak "$FLAT_CMD" "${FINAL_ARGS[@]}"
        ;;
        *)
            if [[ $EXIT_CODE -ne 0 ]] || grep -qiE "target not found|Nenhum pacote|não encontrado" "$TMP_OUT"; then
                echo -e "\n${YELLOW} $NOTE Package not found in AUR. Trying on Flatpak...${NC}\n"
                flatpak "$FLAT_CMD" -y "${FINAL_ARGS[@]}"
                EXIT_CODE=$?
                [[ $EXIT_CODE -eq 0 ]] && TAG="FLATPAK"
            fi
        ;;
    esac
}

#################################
###  END OF FLATPAK SESSION   ###
#################################
### START OF COMMANDS SESSION ###
#################################

## !BASE
ins() {
    tester
    CMD="-S"
    TAG="INSTALLED"
    FLAT_CMD="install"
}

rmv() {
    CMD=$([[ "$AGRESSIVE_MODE" == "true" ]] && echo "-Rsn" || echo "-Rs")
    TAG=$([[ "$AGRESSIVE_MODE" == "true" ]] && echo "REMOVED WITH -Rsn MODE" || echo "REMOVED")
    FLAT_CMD="uninstall"
}

upd() {
    tester
    CMD="-Syu"
    TAG="UPDATED"
    FLAT_CMD="update"
}

## !CACHE
cache_mgr() {
    local cache_dir="$REAL_HOME/.cache/$backend"
    if [[ -d "$cache_dir" ]]; then
        step "Cleaning $backend builds..."
        find "$cache_dir" -maxdepth 1 -type d -not -path "$cache_dir" -exec rm -rf {} +
        success "Builds cleaned."
    fi
    if command -v flatpak &>/dev/null; then
        step "Cleaning unused Flatpaks..."
        flatpak uninstall --unused -y &>/dev/null
        success "Flatpaks cleaned."
    fi
    step "Cleaning pacman cache..."
    CMD="-Sc"
    TAG="CLEANED CACHE"
}

remove_orphans() {
    step "Searching for orphan packages..."
    mapfile -t FINAL_ARGS < <("$backend" -Qqtd 2>/dev/null)
    ORPHANS_N=${#FINAL_ARGS[@]}
    if [[ "$ORPHANS_N" -eq 0 ]]; then
        success "No orphan packages found"
        logger "SEARCHED ORPHANS" "clean"
        exit 0
    fi
    echo "$NOTE $ORPHANS_N Orphans found"
    printf '%s\n' "${FINAL_ARGS[@]}"
    step "Removing orphans..."
    CMD="-Rsn"
    TAG="REMOVED ORPHANS"
}

check_conf() {
    step "Searching for .pacnew/.pacsave files..."
    PACNEWS=$(find /etc -regextype posix-extended -regex ".+\.pac(new|save)" 2>/dev/null)
    if [[ -z "$PACNEWS" ]]; then
        success "All clear! No conflicts found in /etc."
    else
        echo -e "${YELLOW} $NOTE Pending files found:${NC}"
        echo "$PACNEWS"
        echo -e "\n${CYAN} $CC ${NC}Merge now with pacdiff? [y/N]"
        read -r -n 1 opt
        echo
        [[ "$opt" =~ ^(y|Y)$ ]] && sudo pacdiff
    fi
    TAG="CLEAR DIFFS"
}

## !ETC
show_stats() {
    step "Gathering system statistics..."
    local native_pkgs=$(pacman -Qn | wc -l)
    local aur_pkgs=$(pacman -Qm | wc -l)
    local flat_pkgs=0
    if command -v flatpak &>/dev/null; then
        flat_pkgs=$(flatpak list --app | wc -l)
    fi
    local cache_size=$(du -sh /var/lib/pacman | cut -f1)
    local install_date=$(head -n1 /var/log/pacman.log | cut -d' ' -f1 | tr -d '[]' | cut -d'T' -f1)
    local aur_cache_size="0"
    [[ -d "$REAL_HOME/.cache/$backend" ]] && aur_cache_size=$(du -sh "$REAL_HOME/.cache/$backend" | cut -f1)
    local heavy_pkgs=$(expac -S "%m\t%n"  2>/dev/null | sort -hr | head -5 | awk '{print $2 " (" $1/1024/1024 "MB)"}')
    echo -e "\n${CYAN}--- JAY SYSTEM STATS ---${NC}"
    echo -e "${GREEN}Packages:${NC}"
    echo -e "  $CC Native: $native_pkgs"
    echo -e "  $CC AUR:    $aur_pkgs"
    [[ $flat_pkgs -gt 0 ]] && echo -e "  $CC Flatpak: $flat_pkgs"
    echo -e "\n${YELLOW}Disk Usage (Cache):${NC}"
    echo -e "  $CC Pacman DB: $cache_size"
    echo -e "  $CC System Born on: $install_date"
    echo -e "  $CC $backend Cache: $aur_cache_size"
    if command -v expac &>/dev/null; then
        echo -e "\n${RED}Heaviest Packages:${NC}"
        echo "$heavy_pkgs" | sed "s/^/  $CC /"
    else
        echo -e "\n${YELLOW}$NOTE Install 'expac' to see heaviest packages.${NC}"
    fi
    echo -e "${CYAN}------------------------${NC}"
    TAG="STATS"
}

view_pkgbuild() {
    local pkg="$1"
    [[ -z $pkg ]] && echo "$NOTE Specify one package." && exit 1
    step "Searching PKGBUILD for $pkg..."
    local content
    content=$("$backend" -Gp "$pkg" 2>/dev/null)
    if [[ -n "$content" ]]; then
        echo -e "${CYAN}--- PKGBUILD: $pkg ---${NC}\n"
        echo "$content" | less -R
        TAG="VIEW PKGBUILD"
    else
        error "Can't find PKGBUILD for '$pkg'. Is it in the AUR?"
    fi
}

list_aur() {
    step "Filtering packages installed via AUR..."
    "$backend" -Qqm | column -t
    TAG="LOCAL_QUERY (AUR)"
    local count=$("$backend" -Qqm | wc -l)
    echo -e "\n${GREEN}$COMPLETE${NC} Total of $count AUR packages found."
}

refresh_mirrors() {
    step "Starting mirror optimization (Reflector)..."
    if ! command -v reflector &>/dev/null; then
        echo -e "${YELLOW}$NOTE Reflector not found.${NC}"
        read -p "Do you want to install reflector to optimize mirrors? [Y/n] " -n 1 -r
        echo
        if [[ $REPLY =~ ^[Yy]$ ]]; then
            sudo pacman -S reflector --noconfirm
        else
            error "Reflector is required for this function."
        fi
    fi
    detect_country() {
        curl -s --max-time 2 https://ipinfo.io/country 2>/dev/null
    }
    
    if [[ -z "$MIRROR_COUNTRY" ]]; then
        MIRROR_COUNTRY=$(detect_country)
    fi
    REFLECTOR_ARGS=(--latest 20 --protocol https --sort rate)
    if [[ -n "$MIRROR_COUNTRY" ]]; then
        step "Using mirrors from: $MIRROR_COUNTRY"
        REFLECTOR_ARGS+=(--country "$MIRROR_COUNTRY")
    else
        step "Could not detect country, using worldwide mirrors"
    fi
    step "Creating backup at /etc/pacman.d/mirrorlist.bak"
    sudo cp /etc/pacman.d/mirrorlist /etc/pacman.d/mirrorlist.bak
    step "Fetching the fastest mirrors... (Please wait)"
    if sudo reflector "${REFLECTOR_ARGS[@]}" --save /etc/pacman.d/mirrorlist; then
        success "Mirrors updated and saved successfully."
        TAG="UPDATE MIRRORS"
    else
        error "Failed to update mirrors. Check your internet connection."
    fi
}

fix_keys() {
    step "Starting GPG key recovery..."
    "$backend" -S archlinux-keyring --noconfirm --needed 2>&1 | tee "$TMP_OUT"
    if [[ -f "$TMP_OUT" ]]; then
        local keys=$(grep -oP '(?<=key\s)([A-F0-9]{16,})|(?<=ID\s)([A-F0-9]{16,})' "$TMP_OUT" | sort -u)
        if [[ -n "$keys" ]]; then
            for key in $keys; do
                step "Importing key: $key"
                gpg --recv-keys "$key" || gpg --keyserver hkp://keyserver.ubuntu.com:80 --recv-keys "$key"
            done
        fi
    fi
    step "Cleaning corrupted key caches..."
    sudo find /etc/pacman.d/gnupg -type f -name "*.lck" -delete
    sudo pacman-key --init
    sudo pacman-key --populate archlinux
    success "Done."
}

backup_func() {
    case "$BACKUP_ACTION" in
        "create")
            step "Creating backup of packages..."
            mkdir -p "$BACKUP_DIR"
            "$backend" -Qqa > "$BACKUP_FILE"
            CHECKSUM=$(sha256sum "$BACKUP_FILE" | cut -d' ' -f1)
            echo "$CHECKSUM" > "$BACKUP_DIR/backup.sha256"
            success "Backup created successfully in $BACKUP_FILE"
            logger "CREATED BACKUP" "$BACKUP_FILE"
            exit 0
        ;;
        "restore")
            [[ -n "$CUSTOM_PATH" ]] && BACKUP_FILE="$CUSTOM_PATH"
            if [[ ! -f "$BACKUP_FILE" ]]; then
                error "Backup file not found."
            fi
            local backup_base="${BACKUP_FILE%.*}"
            CHECKSUM_FILE="${backup_base}.sha256"
            if [[ ! -f "$CHECKSUM_FILE" ]]; then
                error "Validation key not found. Backup may be invalid or corrupted."
            fi
            step "Validating backup integrity..."
            local stored_hash
            stored_hash=$(cat "$CHECKSUM_FILE")
            local actual_hash
            actual_hash=$(sha256sum "$BACKUP_FILE" | cut -d' ' -f1)
            if [[ "$stored_hash" != "$actual_hash" ]]; then
                error "Backup validation failed. File may be corrupted or tampered."
            fi
            success "Backup integrity verified."
            step "Searching for available backups..."
            success "Backup file found: $BACKUP_FILE"
            step "Restoring backup..."
            mapfile -t PKG_LIST < "$BACKUP_FILE"
            if "$backend" -S "${PKG_LIST[@]}" --needed; then
                success "Backup restored."
                logger "BACKUP RESTORATION" "Reinstalled ${#PKG_LIST[@]} packages"
                exit 0
            else
                error "Restore failed."
            fi
        ;;
    esac
}

## !LOGGER

log_acts() {
    case "$LOG_FUNC" in
        "sl")
            cmd() { tail -n "$LOG_LINES" "$LOG_FILE"; }
            [[ "$LOG_LINES" == "" || "$LOG_LINES" == "null" ]] && cmd() { cat "$LOG_FILE"; }
            [[ ! -s "$LOG_FILE" ]] && echo "$NOTE The log file is empty." && exit 0
            cmd
        ;;
        "cl")
            > "$LOG_FILE"
            echo "$COMPLETE Cleared log file"
            exit 0
        ;;
    esac
}

logger() {
    local status="${EXIT_CODE:-0}"
    local tag="$1"
    local info="$2"
    printf -v date_str '%(%Y-%m-%d - %H:%M:%S)T' -1
    echo "$date_str [Exit Status $status] [$tag] -> $info" >> "$LOG_FILE"
}

## !SEARCH
searcher() {
    tester
    CMD="-Ss"
    TAG="SEARCHED"
    FLAT_CMD="search"
}

query() {
    CMD="-Qs"
    TAG="LOCAL QUERY"
    [[ "$PTBIN" == true ]] && get_package_path "${FINAL_ARGS[@]}" && TAG="SKIP" && return
}

check_updates() {
    tester
    command -v checkupdates &>/dev/null || { step "Installing dependencies..."; "$backend" -S pacman-contrib --noconfirm; }
    step "Searching for updates..."
    local tmp_repo=$(mktemp)
    local tmp_aur=$(mktemp)
    checkupdates > "$tmp_repo" 2>/dev/null &
    local pid_repo=$!
    "$backend" -Qua > "$tmp_aur" 2>/dev/null &
    local pid_aur=$!
    local pid_flat=""
    local tmp_flat=""
    if [[ "$USE_FLATPAK" == "true" ]] && command -v flatpak &>/dev/null; then
        tmp_flat=$(mktemp)
        flatpak remote-ls --updates > "$tmp_flat" 2>/dev/null &
        pid_flat=$!
    fi
    wait $pid_repo $pid_aur ${pid_flat:+$pid_flat}
    local upds_n=$(wc -l < "$tmp_repo")
    local upds_aur_n=$(wc -l < "$tmp_aur")
    local upds_flat_n=0
    [[ -f "$tmp_flat" ]] && upds_flat_n=$(wc -l < "$tmp_flat")
    local total=$((upds_n + upds_aur_n + upds_flat_n))
    if [[ "$total" -eq 0 ]]; then
        success "Your system is updated."
        rm -f "$tmp_repo" "$tmp_aur" ${tmp_flat:+"$tmp_flat"}
        return
    fi
    local flat_info=""
    [[ "$USE_FLATPAK" == "true" ]] && flat_info=" and $upds_flat_n in Flatpak"
    echo -e "${YELLOW} $NOTE $total Updates found ($upds_aur_n in AUR$flat_info):${NC}"
    [[ "$upds_n" -gt 0 ]] && echo -e "\nOfficial upds:\n${CYAN}$(cat "$tmp_repo")${NC}"
    [[ "$upds_aur_n" -gt 0 ]] && echo -e "\nUpdates in AUR:\n${GREEN}$(cat "$tmp_aur")${NC}"
    if [[ "$USE_FLATPAK" == "true" && "$upds_flat_n" -gt 0 ]]; then
        echo -e "\nUpdates in Flatpak:\n${YELLOW}$(cat "$tmp_flat")${NC}"
    fi
    rm -f "$tmp_repo" "$tmp_aur" ${tmp_flat:+"$tmp_flat"}
    logger "FOUND UPDATES" "$total updates (Flatpak: $USE_FLATPAK)"
}

get_package_path() {
    local pkg="$1"
    local bins=$(pacman -Ql "$pkg" 2>/dev/null | awk '/\/bin\// {print $2}')
    if [[ -n "$bins" ]]; then
        echo -e "${GREEN}Binaries found:${NC}\n$bins"
    else
        step "No binaries found in $pkg"
    fi
}

###############################
### END OF COMMANDS SESSION ###
###############################

[[ -f "$LOG_FILE" ]] || touch "$LOG_FILE"
[[ ! -w "$LOG_FILE" ]] && sudo chown "${SUDO_USER:-$USER}":"${SUDO_USER:-$USER}" "$LOG_FILE" 2>/dev/null
[[ -z "$1" ]] && usage

RAW_CMD="$*"; USE_FLATPAK=false; PTBIN=false; AGRESSIVE_MODE=false; FINAL_ARGS=(); YAY_FLAGS=(); LOG_LINES=""

while [[ $# -gt 0 ]]; do
    case "$1" in
        stats|--list-aur|--pacdiff|--ping|--create-backup|--restore-backup|install|-i|remove|-r|update|-u|search|-s|query|-q|cache|-c|orphan|-o|mirrors|-m|slog|-sl|--fix-keys|clog|-cl|--check-updates)
            [[ -z "$ACTION" ]] && ACTION="$1" || FINAL_ARGS+=("$1")
        ;;
        --view)
            [[ -z "$ACTION" ]] && ACTION="--view" || FINAL_ARGS+=("$1")
        ;;
        --backend)
            shift
            if [[ "$1" == "paru" || "$1" == "yay" || "$1" == "pikaur" ]]; then
                backend="$1"
            else
                err04
            fi
        ;;
        --path)
            shift
            [[ -z "$1" ]] && error "--path requires a file path argument"
            CUSTOM_PATH="$1"
        ;;
        --lines)
            shift
            LOG_LINES="$1"
            [[ -z "$LOG_LINES" || "$LOG_LINES" == "" ]] && LOG_LINES="null"
        ;;
        -h|--help) help_message ;;
        --info) inform; exit 0 ;;
        -f|f|\--flatpak) USE_FLATPAK=true ;;
        --flatpak-only) ONLY_FLATPAK=true ;;
        -v|--version) ver_msg; exit 0 ;;
        -A) AGRESSIVE_MODE=true ;;
        --path-to-binary) PTBIN=true ;;
        nc|--noconfirm) YAY_FLAGS+=("--noconfirm") ;;
        -) ACTION="-" && err01 ;;
        -*) ACTION="$1" && err01 ;;
        *) FINAL_ARGS+=("$1") ;;
    esac
    shift
done

[[ -z "$ACTION" && ${#FINAL_ARGS[@]} -gt 0 ]] && ACTION="${FINAL_ARGS[0]}" && FINAL_ARGS=("${FINAL_ARGS[@]:1}")

[[ "$ACTION" =~ ^(install|remove|-i|-r)$ && ${#FINAL_ARGS[@]} -eq 0 ]] && error "specify at least one package"

! command -v "$backend" &>/dev/null && err03

TMP_OUT=$(mktemp) || err02
trap 'rm -f "$TMP_OUT" 2>/dev/null' EXIT

if [[ -n "$ACTION" ]]; then
    [[ "$AGRESSIVE_MODE" == "true" ]] && echo -e "${RED} $NOTE Agressive mode enabled!${NC}"
    { pgrep -x pacman >/dev/null || pgrep -x "$backend" >/dev/null; } && error "Pacman/$backend is already running."
    [[ -f /var/lib/pacman/db.lck ]] && sudo rm /var/lib/pacman/db.lck && success "Database lock removed."
fi

[[ "$ONLY_FLATPAK" == "true" ]] && flatpak_only

case "$ACTION" in
    show-logs|slog|-sl) LOG_FUNC="sl"; log_acts ;;
    clear-logs|clog|-cl) LOG_FUNC="cl"; log_acts ;;
    --ping) tester && logger "TEST FOR NETWORK" "available" && exit 0 ;;
    i|in|ins|install|-i) ins ;;
    r|rm|rem|remove|-r|-rm) rmv ;;
    u|up|upd|update|-u) upd ;;
    s|sr|src|search|-s) searcher ;;
    q|qr|qur|query|-q) query ;;
    c|cc|cac|cache|-c) cache_mgr ;;
    o|op|orp|orphan|-o) remove_orphans ;;
    m|mr|mir|mirrors|-m) refresh_mirrors ;;
    cu|check|--check-updates) check_updates ;;
    fk|--fix-keys) fix_keys ;;
    pd|--pacdiff) check_conf ;;
    stats|--statistics) show_stats ;;
    cb|--create-backup) BACKUP_ACTION="create"; backup_func ;;
    rb|--restore-backup) BACKUP_ACTION="restore"; backup_func ;;
    la|--list-aur) list_aur ;;
    vi|--view) view_pkgbuild "${FINAL_ARGS[0]}"; exit 0 ;;
    *) err01 ;;
esac

[[ "$TAG" == "SKIP" ]] && exit 0

case "$ACTION" in
    search|-s)
        "$backend" "$CMD" "${FINAL_ARGS[@]}" "${YAY_FLAGS[@]}" 2>&1 | tee "$TMP_OUT"
        EXIT_CODE=${PIPESTATUS[0]}
        run_flatpak
    ;;
    *)
        if [[ -n "$CMD" ]]; then
            "$backend" "$CMD" "${FINAL_ARGS[@]}" "${YAY_FLAGS[@]}" 2>&1 | tee "$TMP_OUT"
            EXIT_CODE=${PIPESTATUS[0]}
            run_flatpak
        fi
    ;;
esac

if [[ "$EXIT_CODE" -eq 0 && -n "$TAG" ]]; then
    if grep -qiE "could not find|nenhum pacote|target not found" "$TMP_OUT"; then
        logger "NOT FOUND" "${RAW_CMD}"
    else
        logger "${TAG:-SYSTEM}" "${RAW_CMD}"
    fi
fi