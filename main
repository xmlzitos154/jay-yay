## !CACHE
cache_mgr() {
    local cache_dir="$REAL_HOME/.cache/$backend"
    if [[ -d "$cache_dir" ]];
    then
        step "$MSG_CACHE_CLEANING_BUILDS $backend builds..."
        find "$cache_dir" -maxdepth 1 -type d -not -path "$cache_dir" -exec rm -rf {} +
        success "$MSG_CACHE_BUILDS_CLEANED"
    fi
    if command -v flatpak &>/dev/null; then
        step "$MSG_CACHE_CLEANING_FLATPAK"
        flatpak uninstall --unused -y &>/dev/null
        success "$MSG_CACHE_FLATPAK_CLEANED"
    fi
    step "$MSG_CACHE_CLEANING_PACMAN"
    cmd="-Sc"
    tag="CLEANED CACHE"
}

remove_orphans() {
    step "$MSG_ORPHANS_SEARCHING"
    mapfile -t final_args < <("$backend" -Qqtd 2>/dev/null)
    orphans_n=${#final_args[@]}
    if [[ "$orphans_n" -eq 0 ]];
    then
        success "$MSG_ORPHANS_NONE"
        logger "SEARCHED ORPHANS" "clean"
        exit 0
    fi
    echo "$NOTE $orphans_n $MSG_ORPHANS_FOUND"
    printf '%s\n' "${final_args[@]}"
    step "$MSG_ORPHANS_REMOVING"
    cmd="-Rsn"
    tag="REMOVED ORPHANS"
}

check_conf() {
    step "$MSG_CONF_SEARCHING"
    pacnews=$(find /etc -regextype posix-extended -regex ".+\.pac(new|save)" 2>/dev/null)
    if [[ -z "$pacnews" ]];
    then
        success "$MSG_CONF_NONE"
    else
        echo -e "${YELLOW} $NOTE $MSG_CONF_PENDING${NC}"
        echo "$pacnews"
        echo -e "\n${CYAN} $CC ${NC}$MSG_CONF_MERGE_PROMPT"
        read -r -n 1 opt
        echo
        [[ "$opt" =~ ^[yYgGsS]$ ]] && sudo pacdiff
    fi
    tag="CLEAR DIFFS"
}

## !ETC
create_snapshot() {
    if [[ "$dry_run" == "true" ]]; then
        echo -e "${CYAN}[DRY RUN] Would run:${NC} sudo timeshift --create --comments \"JAY Auto-Snapshot\" --tags D"
        return
    fi
    
    step "$MSG_SNAP_CHECK"
    if command -v timeshift &>/dev/null; then
        step "$MSG_SNAP_CREATING"
        sudo timeshift --create --comments "JAY Auto-Snapshot before update" --tags D
        if [[ $? -eq 0 ]]; then
            success "$MSG_SNAP_SUCCESS"
        else
            echo -e "${YELLOW} $NOTE Warning: Snapshot backup failed, but continuing update...${NC}"
        fi
    else
        echo -e "${YELLOW} $NOTE $MSG_SNAP_NOT_FOUND${NC}"
    fi
}

pin() {
    local pkg="${final_args[0]}"
    local conf="/etc/pacman.conf"
    [[ -z "$pkg" ]] && error "$MSG_DEPS_SPECIFY"
     
    local current
    current=$(grep -oP '(?<=^IgnorePkg = ).*' "$conf")
    
    if echo "$current" | grep -qw "$pkg"; then
        local new
        new=$(echo "$current" | sed "s/\b$pkg\b//" | tr -s ' ' | sed 's/^ //;s/ $//')
        sudo sed -i "s/^IgnorePkg = .*/IgnorePkg = $new/" "$conf"
        success "$pkg unpinned."
        logger "UNPIN" "$pkg"
    elif grep -q "^IgnorePkg" "$conf";
    then
        sudo sed -i "s/^IgnorePkg = .*/IgnorePkg = $current $pkg/" "$conf"
        success "$pkg pinned."
        logger "PIN" "$pkg"
    elif grep -q "^#IgnorePkg" "$conf";
    then
        sudo sed -i "s/^#IgnorePkg.*/IgnorePkg = $pkg/" "$conf"
        success "$pkg pinned."
        logger "PIN" "$pkg"
    else
        sudo sed -i "/^\[options\]/a IgnorePkg = $pkg" "$conf"
        success "$pkg pinned."
        logger "PIN" "$pkg"
    fi
}

depends() {
    command -v pactree &>/dev/null && { step "$MSG_INSTALL_CONTRIB pacman-contrib..."; "$backend" -S pacman-contrib --noconfirm; }
    local pkg="${final_args[0]}"
    [[ -z "$pkg" ]] && echo -e "$ALERT $MSG_DEPS_SPECIFY" && exit 1
    ! pacman -Qi "$pkg" &>/dev/null && echo -e "$ERROR ${YELLOW}$MSG_DEPS_NOT_FOUND '$pkg'" && exit 1
    step "$MSG_DEPS_CHECKING '$pkg'..."
    local deps_n
    local deps
    deps=$(pactree -r "$pkg" 2>/dev/null | tail -n +2)
    deps_n=$(echo "$deps" | wc -l)
    if [[ -z "$deps" ]];
    then
        success "$MSG_DEPS_NONE $pkg."
        logger "WHY" "$pkg -> No dependencies"
        exit 0
    fi
    echo -e "\n $NOTE $deps_n $MSG_DEPS_FOUND_COUNT"
    echo -e "${YELLOW} $CC '$pkg' $MSG_DEPS_REQUIRED_BY${NC}"
    echo "$deps" | sed 's/^/  /'
    echo -e "\n${CYAN} $NOTE $MSG_DEPS_SUGGESTED_ORDER${NC}"
    local pkgs
    pkgs=$(echo "$deps" | grep -oP '[\w][\w.+@-]+' | awk '!seen[$0]++' | tr '\n' ' ')
    echo "  jay -r $pkgs"
    logger "WHY" "$pkg"
}

show_stats() {
    step "$MSG_STATS_GATHERING"
    local native_pkgs=$(pacman -Qn | wc -l)
    local aur_pkgs=$(pacman -Qm | wc -l)
    local flat_pkgs=0
    if command -v flatpak &>/dev/null;
    then
        flat_pkgs=$(flatpak list --app | wc -l)
    fi
    local cache_size=$(du -sh /var/lib/pacman | cut -f1)
    local install_date=$(head -n1 /var/log/pacman.log | cut -d' ' -f1 | tr -d '[]' | cut -d'T' -f1)
    local aur_cache_size="0"
    [[ -d "$REAL_HOME/.cache/$backend" ]] && aur_cache_size=$(du -sh "$REAL_HOME/.cache/$backend" | cut -f1)
    echo -e "\n${YELLOW}$MSG_STATS_TITLE${NC}"
    echo -e "${GREEN}$MSG_STATS_PACKAGES${NC}"
    echo -e "  $CC $MSG_STATS_NATIVE $native_pkgs"
    echo -e "  $CC AUR:    $aur_pkgs"
    [[ $flat_pkgs -gt 0 ]] && echo -e "  $CC Flatpak: $flat_pkgs"
    echo -e "\n${CYAN}$MSG_STATS_DISK_USAGE${NC}"
    echo -e "  $CC $MSG_STATS_PACMAN_DB $cache_size"
    echo -e "  $CC $MSG_STATS_BORN_ON $install_date"
    echo -e "  $CC $backend Cache: $aur_cache_size"
    if command -v expac &>/dev/null;
    then
        echo -e "\n${YELLOW}$MSG_STATS_HEAVIEST${NC}"
        expac "%m %n" | sort -rn | head -10 | awk '{printf "  %s MB\t%s\n", $1/1024/1024, $2}'
    else
        echo -e "\n${YELLOW}$NOTE $MSG_STATS_EXPAC_WARN${NC}"
    fi
    echo -e "${CYAN}------------------------${NC}"
    tag="STATS"
}

view_pkgbuild() {
    local pkg="$1"
    [[ -z $pkg ]] && echo "$NOTE $MSG_PKGB_SPECIFY" && exit 1
    step "$MSG_PKGB_SEARCHING $pkg..."
    local content
    content=$("$backend" -Gp "$pkg" 2>/dev/null)
    if [[ -n "$content" ]];
    then
        echo -e "${CYAN}--- PKGBUILD: $pkg ---${NC}\n"
        echo "$content" | less -R
        tag="VIEW PKGBUILD"
    else
        error "$MSG_PKGB_NOT_FOUND '$pkg'. $MSG_PKGB_AUR_QUESTION"
    fi
}

list_aur() {
    step "$MSG_AUR_FILTERING"
    "$backend" -Qqm | column -t
    tag="LOCAL_QUERY (AUR)"
    local count=$("$backend" -Qqm | wc -l)
    echo -e "\n${GREEN}$COMPLETE${NC} $MSG_AUR_TOTAL_FOUND $count $MSG_AUR_PKGS_FOUND"
}

detect_country() {
    mirror_country="$(curl -s --max-time 2 https://ipinfo.io/country 2>/dev/null)"
}

refresh_mirrors() {
    step "$MSG_MIRROR_START"
    if ! command -v reflector &>/dev/null; then
        echo -e "${YELLOW}$NOTE $MSG_REFLECTOR_NOT_FOUND${NC}"
        read -p "$MSG_INSTALL_REFLECTOR_PROMPT" -n 1 -r
        if [[ "$REPLY" =~ ^[YySs]$ || -z "$REPLY" ]]; then
            echo
            sudo pacman -S reflector --noconfirm
        else
            echo
            error "$MSG_REFLECTOR_REQUIRED"
        fi
    fi
    
    detect_country
    reflector_args=(--latest 20 --protocol https --sort rate)
    if [[ -n "$mirror_country" ]]; then
        step "$MSG_USING_MIRRORS_FROM $mirror_country"
        reflector_args+=(--country "$mirror_country")
    else
        step "$MSG_NO_COUNTRY_WORLDWIDE"
    fi
    
    step "$MSG_MIRROR_BACKUP"
    sudo cp /etc/pacman.d/mirrorlist /etc/pacman.d/mirrorlist.bak
    step "$MSG_FETCHING_MIRRORS"
    
    if sudo reflector "${reflector_args[@]}" --save /etc/pacman.d/mirrorlist; then
        success "$MSG_MIRRORS_SUCCESS"
        tag="UPDATE MIRRORS"
    else
        error "$MSG_MIRRORS_FAILED"
    fi
}

fix_keys() {
    step "$MSG_GPG_START"
    "$backend" -S archlinux-keyring --noconfirm --needed 2>&1 | tee "$tmp_out"
    if [[ -f "$tmp_out" ]]; then
        local keys=$(grep -oP '(?<=key\s)([A-F0-9]{16,})|(?<=ID\s)([A-F0-9]{16,})' "$tmp_out" | sort -u)
        if [[ -n "$keys" ]]; then
            for key in $keys; do
                step "$MSG_IMPORTING_KEY $key"
                gpg --recv-keys "$key" || gpg --keyserver hkp://keyserver.ubuntu.com:80 --recv-keys "$key"
            done
        fi
    fi
    step "$MSG_CLEANING_KEY_CACHE"
    sudo find /etc/pacman.d/gnupg -type f -name "*.lck" -delete
    sudo pacman-key --init
    sudo pacman-key --populate archlinux
    success "$MSG_DONE"
}

fix_keys() {
    step "Starting GPG key recovery..."
    "$backend" -S archlinux-keyring --noconfirm --needed 2>&1 | tee "$tmp_out"
    if [[ -f "$tmp_out" ]]; then
        local keys=$(grep -oP '(?<=key\s)([A-F0-9]{16,})|(?<=ID\s)([A-F0-9]{16,})' "$tmp_out" | sort -u)
        if [[ -n "$keys" ]]; then
            for key in $keys; do
                step "Importing key: $key"
                gpg --recv-keys "$key" || gpg --keyserver hkp://keyserver.ubuntu.com:80 --recv-keys "$key"
            done
        fi
    fi
    step "Cleaning corrupted key caches..."
    sudo find /etc/pacman.d/gnupg -type f -name "*.lck" -delete
    sudo pacman-key --init
    sudo pacman-key --populate archlinux
    success "Done."
}

backup_func() {
    case "$backup_action" in
        "create")
            step "Creating backup of packages..."
            mkdir -p "$BACKUP_DIR"
            "$backend" -Qqa > "$BACKUP_FILE"
            checksum=$(sha256sum "$BACKUP_FILE" | cut -d' ' -f1)
            echo "$checksum" > "$BACKUP_DIR/backup.sha256"
            success "Backup created successfully in $BACKUP_FILE"
            logger "CREATED BACKUP" "$BACKUP_FILE"
            exit 0
        ;;
        "restore")
            [[ -n "$custom_path" ]] && BACKUP_FILE="$custom_path"
            if [[ ! -f "$BACKUP_FILE" ]]; then
                error "Backup file not found."
            fi
            local backup_base="${BACKUP_FILE%.*}"
            checksum_file="${backup_base}.sha256"
            if [[ ! -f "$checksum_file" ]]; then
                error "Validation key not found. Backup may be invalid or corrupted."
            fi
            step "Validating backup integrity..."
            local stored_hash
            stored_hash=$(cat "$checksum_file")
            local actual_hash
            actual_hash=$(sha256sum "$BACKUP_FILE" | cut -d' ' -f1)
            if [[ "$stored_hash" != "$actual_hash" ]]; then
                error "Backup validation failed. File may be corrupted or tampered."
            fi
            success "Backup integrity verified."
            step "Restoring backup..."
            mapfile -t pkg_list < "$BACKUP_FILE"
            if "$backend" -S "${pkg_list[@]}" --needed; then
                success "Backup restored."
                logger "BACKUP RESTORATION" "Reinstalled ${#pkg_list[@]} packages"
                exit 0
            else
                error "Restore failed."
            fi
        ;;
    esac
}

## !LOG_MANAGER

sl() {
    [[ ! -s "$LOG_FILE" ]] && echo "$NOTE $MSG_EMPTY_LOG" && exit 0
    if [[ -n "$log_lines" && "$log_lines" =~ ^[0-9]+$ ]]; then
        tail -n "$log_lines" "$LOG_FILE"
    else
        cat "$LOG_FILE"
    fi
}

cl() {
    [[ ! -s "$LOG_FILE" ]] && echo "$NOTE The log file is empty." && exit 0
    echo "" > "$LOG_FILE"
    success "Done."
}

logger() {
    local status="${exit_code:-0}"
    local tag="$1"
    local info="$2"
    printf -v date_str '%(%Y-%m-%d - %H:%M:%S)T' -1
    echo "$date_str [Exit Status $status] [$tag] -> $info" >> "$LOG_FILE"
}

## !SEARCH
searcher() {
    tester
    cmd="-Ss"
    tag="SEARCHED"
    flat_cmd="search"
}

query() {
    cmd="-Qs"
    tag="LOCAL QUERY"
    [[ "$ptbin" == true ]] && get_package_path "${final_args[@]}" && tag="SKIP" && return
}

check_updates() {
    tester
    command -v checkupdates &>/dev/null || { step "$MSG_INSTALL_DEPS"; "$backend" -S pacman-contrib --noconfirm; }
    step "$MSG_SEARCHING_UPDATES"
    local tmp_repo=$(mktemp)
    local tmp_aur=$(mktemp)
    checkupdates > "$tmp_repo" 2>/dev/null &
    local pid_repo=$!
    "$backend" -Qua > "$tmp_aur" 2>/dev/null &
    local pid_aur=$!
    local pid_flat=""
    local tmp_flat=""
    if [[ "$use_flatpak" == "true" ]] && command -v flatpak &>/dev/null; then
        tmp_flat=$(mktemp)
        flatpak remote-ls --updates > "$tmp_flat" 2>/dev/null &
        pid_flat=$!
    fi
    wait $pid_repo $pid_aur ${pid_flat:+$pid_flat}
    local upds_n=$(wc -l < "$tmp_repo")
    local upds_aur_n=$(wc -l < "$tmp_aur")
    local upds_flat_n=0
    [[ -f "$tmp_flat" ]] && upds_flat_n=$(wc -l < "$tmp_flat")
    local total=$((upds_n + upds_aur_n + upds_flat_n))
    if [[ "$total" -eq 0 ]]; then
        success "$MSG_SYSTEM_UPDATE" [cite: 157]
        rm -f "$tmp_repo" "$tmp_aur" ${tmp_flat:+"$tmp_flat"}
        return
    fi
    local flat_info=""
    [[ "$use_flatpak" == "true" ]] && flat_info=" $MSG_AND $upds_flat_n $MSG_IN_FLATPAK"
    echo -e "${YELLOW} $NOTE $total $MSG_UPDATES_FOUND ($upds_aur_n $MSG_IN_AUR$flat_info):${NC}"
    
    [[ "$upds_n" -gt 0 ]] && echo -e "\n$MSG_OFFICIAL_UPDATES\n${CYAN}$(cat "$tmp_repo")${NC}"
    [[ "$upds_aur_n" -gt 0 ]] && echo -e "\n$MSG_AUR_UPDATES\n${GREEN}$(cat "$tmp_aur")${NC}"
    if [[ "$use_flatpak" == "true" && "$upds_flat_n" -gt 0 ]]; then
        echo -e "\n$MSG_FLATPAK_UPDATES\n${YELLOW}$(cat "$tmp_flat")${NC}"
    fi
    rm -f "$tmp_repo" "$tmp_aur" ${tmp_flat:+"$tmp_flat"}
    logger "FOUND UPDATES" "$total updates (Flatpak: $use_flatpak)"
}

get_package_path() {
    local pkg="$1"
    local bins=$(pacman -Ql "$pkg" 2>/dev/null | awk '/\/bin\// {print $2}')
    if [[ -n "$bins" ]]; then
        echo -e "${GREEN}Binaries found:${NC}\n$bins"
    else
        step "No binaries found in $pkg"
    fi
}

[[ -f "$LOG_FILE" ]] || touch "$LOG_FILE"
[[ ! -w "$LOG_FILE" ]] && sudo chown "${SUDO_USER:-$USER}":"${SUDO_USER:-$USER}" "$LOG_FILE" 2>/dev/null
[[ -z "$1" ]] && usage

raw_cmd="$*"; use_flatpak=false; ptbin=false; agressive_mode=false; final_args=(); yay_flags=(); log_lines=""; dry_run=false; verbose_mode=false
log_rotate

while [[ $# -gt 0 ]]; do
    case "$1" in
        --create-snapshot|dp|why|--ignore|pin|stats|--list-aur|--pacdiff|--ping|--create-backup|--restore-backup|install|-i|remove|-r|update|-u|search|-s|query|-q|cache|-c|orphan|-o|mirrors|-m|slog|-cl|-sl|--fix-keys|--check-updates)
            [[ -z "$action" ]] && action="$1" || final_args+=("$1")
        ;;
        --view)
            [[ -z "$action" ]] && action="--view" || final_args+=("$1")
        ;;
        --backend)
            shift
            if [[ "$1" == "paru" || "$1" == "yay" || "$1" == "pikaur" ]]; then
                backend="$1"
            else
                err04
            fi
        ;;
        --path)
            shift
            [[ -z "$1" ]] && error "--path requires a file path argument"
            custom_path="$1"
        ;;
        --lines)
            shift
            log_lines="$1"
        ;;
        -h|--help) help_message ;;
        --info) inform; exit 0 ;;
        -f|--flatpak) use_flatpak=true ;;
        --flatpak-only) only_flatpak=true ;;
        -v|--version) display_ver; exit 0 ;;
        -A) agressive_mode=true ;;
        --path-to-binary) ptbin=true ;;
        --dry-run) dry_run=true ;;
        nc|--noconfirm) yay_flags+=("--noconfirm") ;;
        -) action="-" && err01 ;;
        -*) action="$1" && err01 ;;
        *) final_args+=("$1") ;;
    esac
    shift
done

[[ -z "$action" && ${#final_args[@]} -gt 0 ]] && action="${final_args[0]}" && final_args=("${final_args[@]:1}")

[[ "$action" =~ ^(install|remove|-i|-r)$ && ${#final_args[@]} -eq 0 ]] && error "$MSG_SPECIFY_PKG"

! command -v "$backend" &>/dev/null && err03

tmp_out=$(mktemp) || err02
trap 'rm -f "$tmp_out" 2>/dev/null' EXIT

if [[ -f /var/lib/pacman/db.lck ]]; then
    { pgrep -x pacman >/dev/null || pgrep -x "$backend" >/dev/null; } && error "$MSG_PACMAN_RUNNING"
    sudo rm /var/lib/pacman/db.lck && success "$MSG_LOCK_REMOVED"
fi

if [[ -n "$action" ]]; then
    [[ "$agressive_mode" == "true" ]] && echo -e "${RED} $NOTE $MSG_AGRESSIVE_MODE${NC}"
fi

[[ "$only_flatpak" == "true" ]] && flatpak_only

case "$action" in
    show-logs|slog|-sl) sl ;;
    clear-logs|clog|-cl) cl ;;
    --ping) tester && logger "TEST FOR NETWORK" "available" && exit 0 ;;
    snap|--create-snapshot) create_snapshot ;;
    i|in|ins|install|-i) ins ;;
    r|rm|rem|remove|-r|-rm) rmv ;;
    u|up|upd|update|-u) upd ;;
    s|sr|src|search|-s) searcher ;;
    q|qr|qur|query|-q) query ;;
    c|cc|cac|cache|-c) cache_mgr ;;
    o|op|orp|orphan|-o) remove_orphans ;;
    m|mr|mir|mirrors|-m) refresh_mirrors ;;
    cu|check|--check-updates) check_updates ;;
    fk|--fix-keys) fix_keys ;;
    pd|--pacdiff) check_conf ;;
    cb|--create-backup) backup_action="create"; backup_func ;;
    rb|--restore-backup) backup_action="restore"; backup_func ;;
    pin|--ignore) pin ;;
    la|--list-aur) list_aur ;;
    dp|why) depends ;;
    vi|--view) view_pkgbuild "${final_args[0]}"; exit 0 ;;
    stats|statistics) show_stats ;;
    *) err01 ;;
esac

[[ "$tag" == "SKIP" ]] && exit 0

if [[ "$dry_run" == "true" ]]; then
    echo -e "\n${YELLOW}$MSG_DRY_RUN_SIM${NC}"
    if [[ -n "$cmd" ]]; then
        echo -e "${CYAN}$MSG_DRY_RUN_RUN${NC} $backend $cmd ${final_args[*]} ${yay_flags[*]}"
    fi
    if [[ "$use_flatpak" == "true" && -n "$flat_cmd" ]]; then
        echo -e "${CYAN}$MSG_DRY_RUN_RUN${NC} flatpak $flat_cmd ${final_args[*]}"
    fi
    echo -e "${GREEN}$MSG_DRY_RUN_NONE${NC}\n"
    exit 0
fi

case "$action" in
    search|-s)
        "$backend" "$cmd" "${final_args[@]}" "${yay_flags[@]}" 2>&1 | tee "$tmp_out"
        exit_code=${PIPESTATUS[0]}
        run_flatpak
    ;;
    *)
        if [[ -n "$cmd" ]]; then
            "$backend" "$cmd" "${final_args[@]}" "${yay_flags[@]}" 2>&1 | tee "$tmp_out"
            exit_code=${PIPESTATUS[0]}
            run_flatpak
        fi
    ;;
esac

if [[ "$exit_code" -eq 0 && -n "$tag" ]]; then
    if grep -qiE "could not find|nenhum pacote|target not found" "$tmp_out"; then
        logger "NOT FOUND" "${raw_cmd}"
    else
        logger "${tag:-SYSTEM}" "${raw_cmd}"
    fi
fi